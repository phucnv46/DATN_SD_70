@model DATN_70.Models.ViewModels.ChangePasswordViewModel
@{
    ViewData["Title"] = "Đổi mật khẩu";
}

<div class="container my-5">
    <div class="row">
        <div class="col-md-3 mb-4">
            <div class="list-group shadow-sm border-0">
                <a href="/Account/Profile" class="list-group-item list-group-item-action">
                    <i class="bi bi-person me-2"></i> Tài khoản của tôi
                </a>
                <a href="/Account/Orders" class="list-group-item list-group-item-action">
                    <i class="bi bi-bag me-2"></i> Đơn hàng của tôi
                </a>
                <a href="/Account/Addresses" class="list-group-item list-group-item-action">
                    <i class="bi bi-geo-alt me-2"></i> Địa chỉ giao hàng
                </a>
                <a href="/Account/Password" class="list-group-item list-group-item-action active bg-dark border-dark">
                    <i class="bi bi-shield-lock me-2"></i> Đổi mật khẩu
                </a>
                <a href="/Account/Logout" class="list-group-item list-group-item-action text-danger border-top">
                    <i class="bi bi-box-arrow-right me-2"></i> Đăng xuất
                </a>
            </div>
        </div>

        <div class="col-md-9">
            <div class="card shadow-sm border-0 p-4 bg-white rounded">
                <div class="border-bottom pb-3 mb-4">
                    <h4 class="fw-bold text-uppercase">Đổi mật khẩu</h4>
                    <p class="text-muted small mb-0">Để bảo mật tài khoản, vui lòng không chia sẻ mật khẩu cho người khác.</p>
                </div>

                @if (Model != null && !string.IsNullOrWhiteSpace(Model.StatusMessage))
                {
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        <i class="bi bi-check-circle-fill me-2"></i> @Model.StatusMessage
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                <div class="row">
                    <div class="col-md-8 col-lg-6">
                        <form asp-controller="Account" asp-action="Password" method="post" autocomplete="off">
                            @Html.AntiForgeryToken()

                            <div class="mb-3">
                                <label class="form-label small fw-medium" asp-for="CurrentPassword">Mật khẩu hiện tại</label>
                                <input type="password" class="form-control" asp-for="CurrentPassword" placeholder="Nhập mật khẩu hiện tại" />
                                <span asp-validation-for="CurrentPassword" class="text-danger small"></span>
                            </div>

                            <div class="mb-3">
                                <label class="form-label small fw-medium" asp-for="NewPassword">Mật khẩu mới</label>
                                <input type="password" class="form-control" asp-for="NewPassword" placeholder="Nhập mật khẩu mới" />
                                <span asp-validation-for="NewPassword" class="text-danger small"></span>
                            </div>

                            <div class="mb-4">
                                <label class="form-label small fw-medium" asp-for="ConfirmPassword">Xác nhận mật khẩu mới</label>
                                <input type="password" class="form-control" asp-for="ConfirmPassword" placeholder="Nhập lại mật khẩu mới" />
                                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                            </div>

                            <button type="submit" class="btn btn-dark px-4 fw-medium">Lưu mật khẩu mới</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>