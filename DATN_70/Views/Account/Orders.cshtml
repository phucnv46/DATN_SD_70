@model DATN_70.Models.ViewModels.AccountOrdersPageViewModel
@{
    ViewData["Title"] = "Đơn hàng của tôi";

    string GetBadgeClass(string statusKey)
    {
        return statusKey switch
        {
            "pending" => "bg-warning text-dark",
            "confirmed" => "bg-info text-dark",
            "preparing" => "bg-primary",
            "shipping" => "bg-primary",
            "success" => "bg-success",
            "cancelled" => "bg-danger",
            "return_pending" => "bg-warning text-dark border border-warning",
            "return_rejected" => "bg-danger-subtle text-danger border border-danger",
            "returned" => "bg-light text-dark border border-dark fw-bold", // Màu chữ đen nền xám nhạt tinh tế
            _ => "bg-secondary"
        };
    }
}

<div class="container my-5">
    <div class="row">
        <div class="col-md-3 mb-4">
            <div class="list-group shadow-sm border-0">
                <a href="/Account/Profile" class="list-group-item list-group-item-action">
                    <i class="bi bi-person me-2"></i> Tài khoản của tôi
                </a>
                <a href="/Account/Orders" class="list-group-item list-group-item-action active bg-dark border-dark">
                    <i class="bi bi-bag me-2"></i> Đơn hàng của tôi
                </a>
                <a href="/Account/Addresses" class="list-group-item list-group-item-action">
                    <i class="bi bi-geo-alt me-2"></i> Địa chỉ giao hàng
                </a>
                <a href="/Account/Password" class="list-group-item list-group-item-action">
                    <i class="bi bi-shield-lock me-2"></i> Đổi mật khẩu
                </a>
                <a href="/Account/Logout" class="list-group-item list-group-item-action text-danger border-top">
                    <i class="bi bi-box-arrow-right me-2"></i> Đăng xuất
                </a>
            </div>
        </div>

        <div class="col-md-9">
            <div class="card shadow-sm border-0 p-4 bg-white rounded">
                <div class="border-bottom pb-3 mb-4">
                    <h4 class="fw-bold text-uppercase">Lịch sử đơn hàng</h4>
                    <p class="text-muted small mb-0">Theo dõi trạng thái và chi tiết các đơn hàng bạn đã đặt.</p>
                </div>

                @if (TempData["OrderStatusMessage"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show small mb-4" role="alert">
                        <i class="bi bi-check-circle-fill me-2"></i> @TempData["OrderStatusMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }
                @if (TempData["OrderErrorMessage"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show small mb-4" role="alert">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["OrderErrorMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                <div class="nav nav-pills mb-4 overflow-auto flex-nowrap pb-2" style="white-space: nowrap; border-bottom: 1px solid #eee;">
                    <a class="nav-link px-3 py-2 me-2 rounded-pill @(Model.CurrentFilter == "all" ? "active bg-dark" : "text-dark bg-light")" href="/Account/Orders?status=all">Tất cả</a>
                    <a class="nav-link px-3 py-2 me-2 rounded-pill @(Model.CurrentFilter == "pending" ? "active bg-dark" : "text-dark bg-light")" href="/Account/Orders?status=pending">Chờ xác nhận</a>
                    <a class="nav-link px-3 py-2 me-2 rounded-pill @(Model.CurrentFilter == "confirmed" ? "active bg-dark" : "text-dark bg-light")" href="/Account/Orders?status=confirmed">Đã xác nhận</a>
                    <a class="nav-link px-3 py-2 me-2 rounded-pill @(Model.CurrentFilter == "preparing" ? "active bg-dark" : "text-dark bg-light")" href="/Account/Orders?status=preparing">Đang chuẩn bị</a>
                    <a class="nav-link px-3 py-2 me-2 rounded-pill @(Model.CurrentFilter == "shipping" ? "active bg-dark" : "text-dark bg-light")" href="/Account/Orders?status=shipping">Đang giao</a>
                    <a class="nav-link px-3 py-2 me-2 rounded-pill @(Model.CurrentFilter == "success" ? "active bg-dark" : "text-dark bg-light")" href="/Account/Orders?status=success">Thành công</a>
                    <a class="nav-link px-3 py-2 me-2 rounded-pill @(Model.CurrentFilter == "cancelled" ? "active bg-dark" : "text-dark bg-light")" href="/Account/Orders?status=cancelled">Đã hủy</a>
                </div>

                @if (Model.Orders == null || !Model.Orders.Any())
                {
                    <div class="text-center py-5">
                        <i class="bi bi-box-seam display-1 text-light"></i>
                        <h5 class="mt-3 text-muted">Chưa có đơn hàng nào</h5>
                        <p class="text-muted small">Bạn chưa có đơn hàng nào trong trạng thái này.</p>
                        <a href="/Home/Products" class="btn btn-outline-dark mt-2">Tiếp tục mua sắm</a>
                    </div>
                }
                else
                {
                    foreach (var order in Model.Orders)
                    {
                        <div class="card border mb-4">
                            <div class="card-header bg-light d-flex justify-content-between align-items-center py-3">
                                <div>
                                    <span class="fw-bold">Mã đơn: @order.Id</span>
                                    <span class="text-muted small ms-3"><i class="bi bi-clock me-1"></i> @order.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span>
                                </div>
                                <span class="badge @GetBadgeClass(order.StatusKey) px-3 py-2 rounded-pill">@order.StatusLabel</span>
                            </div>

                            <div class="card-body">
                                @foreach (var item in order.Items)
                                {
                                    <div class="d-flex justify-content-between align-items-center mb-3">
                                        <div class="d-flex align-items-center">
                                            <div class="bg-light rounded d-flex justify-content-center align-items-center me-3" style="width: 60px; height: 60px;">
                                                <i class="bi bi-image text-muted fs-4"></i>
                                            </div>
                                            <div>
                                                <h6 class="mb-1 fw-medium">@item.ProductName</h6>
                                                <div class="text-muted small">Phân loại: @item.Variant | Số lượng: @item.Quantity</div>
                                            </div>
                                        </div>
                                        <div class="fw-medium text-end">
                                            @((item.UnitPrice * item.Quantity).ToString("N0")) đ
                                        </div>
                                    </div>
                                }
                            </div>

                            <div class="card-footer bg-white py-3">
                                <div class="row align-items-center">
                                    <div class="col-md-7 text-muted small">
                                        <div><strong>Người nhận:</strong> @order.RecipientName - @order.Phone</div>
                                        <div><strong>Giao đến:</strong> @order.ShippingAddress</div>
                                    </div>
                                    <div class="col-md-5 text-end mt-3 mt-md-0">
                                        <div class="mb-2">
                                            <span class="text-muted small me-2">Thành tiền:</span>
                                            <span class="fw-bold text-danger fs-5">@order.TotalAmount.ToString("N0") đ</span>
                                        </div>

                                        @if (order.StatusKey == "pending" || order.StatusKey == "confirmed" || order.StatusKey == "preparing")
                                        {
                                            <form asp-controller="Account" asp-action="CancelOrder" asp-route-id="@order.Id" method="post" onsubmit="return confirm('Bạn có chắc chắn muốn hủy đơn hàng này không?');" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-outline-danger px-3 rounded-pill fw-medium">
                                                    <i class="bi bi-x-circle me-1"></i> Hủy đơn hàng
                                                </button>
                                            </form>
                                        }
                                        else if (order.StatusKey == "success")
                                        {
                                            // CHỈ HIỂN THỊ NÚT KHI ĐƠN THÀNH CÔNG VÀ CHƯA CÓ PHIẾU KHIẾU NẠI ĐỔI TRẢ NÀO
                                            <button type="button" class="btn btn-sm btn-warning px-3 rounded-pill fw-medium btn-open-rma"
                                                    data-id="@order.Id"
                                                    data-items='@Html.Raw(System.Text.Json.JsonSerializer.Serialize(order.Items))'>
                                                <i class="bi bi-arrow-counterclockwise me-1"></i> Yêu cầu Đổi / Trả
                                            </button>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>
<div class="modal fade" id="customerReturnModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-light">
                <h5 class="modal-title fw-bold"><i class="bi bi-arrow-counterclockwise me-2"></i>Phiếu Yêu Cầu Đổi / Trả</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="frmCustomerReturn">
                <input type="hidden" id="rmaOrderId" />
                <div class="modal-body p-4">
                    <p class="small text-muted mb-3">Vui lòng chọn các sản phẩm bạn muốn đổi/trả và nêu rõ lý do. Lưu ý: Sản phẩm phải còn nguyên tem mác.</p>

                    <div class="table-responsive mb-3 border rounded">
                        <table class="table table-borderless align-middle small mb-0">
                            <thead class="bg-light border-bottom">
                                <tr>
                                    <th style="width:40px;">Chọn</th>
                                    <th>Sản phẩm</th>
                                    <th style="width:100px;">SL mua</th>
                                    <th style="width:100px;">SL trả</th>
                                    <th>Lý do</th>
                                </tr>
                            </thead>
                            <tbody id="rmaItemsBody"></tbody>
                        </table>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-medium">Ghi chú thêm cho cửa hàng (Tùy chọn)</label>
                        <textarea class="form-control form-control-sm" id="rmaNote" rows="2" placeholder="Ví dụ: Áo bị chật phần vai, tôi muốn đổi sang size L..."></textarea>
                    </div>
                </div>
                <div class="modal-footer border-top-0 pt-0">
                    <button type="button" class="btn btn-secondary btn-sm rounded-pill px-4" data-bs-dismiss="modal">Đóng</button>
                    <button type="submit" class="btn btn-warning btn-sm rounded-pill fw-bold text-dark px-4">Gửi Yêu Cầu Đổi Trả</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Hiển thị Modal khi khách bấm nút Yêu cầu Đổi/Trả
            $('.btn-open-rma').click(function() {
                const orderId = $(this).data('id');
                const items = $(this).data('items'); // Lấy JSON sản phẩm trực tiếp từ HTML

                $('#rmaOrderId').val(orderId);
                $('#rmaNote').val('');
                $('#rmaItemsBody').empty();

                let html = '';
                items.forEach(item => {
                    // ĐÃ SỬA: Đổi chữ cái đầu thành Viết Hoa (ChiTietSanPhamId, ProductName, Variant, Quantity) để khớp 100% với C#
                    html += `
                        <tr class="rma-item-row" data-id="${item.ChiTietSanPhamId}">
                            <td><input type="checkbox" class="form-check-input chk-rma" style="cursor:pointer;" /></td>
                            <td>
                                <div class="fw-bold text-dark">${item.ProductName}</div>
                                <div class="text-muted" style="font-size:0.75rem;">Phân loại: ${item.Variant}</div>
                            </td>
                            <td class="text-center text-muted">${item.Quantity}</td>
                            <td><input type="number" class="form-control form-control-sm txt-rma-qty" min="1" max="${item.Quantity}" value="1" disabled /></td>
                            <td>
                                <select class="form-select form-select-sm sel-rma-reason" disabled>
                                    <option value="1">Sai Kích cỡ / Màu sắc</option>
                                    <option value="0">Hàng lỗi / Rách / Bẩn</option>
                                    <option value="2">Giao thiếu / Sai mẫu</option>
                                    <option value="3">Lý do Khác</option>
                                </select>
                            </td>
                        </tr>`;
                });
                $('#rmaItemsBody').html(html);
                $('#customerReturnModal').modal('show');
            });

            // Mở khóa ô nhập liệu khi khách hàng tick chọn trả sản phẩm
            $(document).on('change', '.chk-rma', function() {
                const row = $(this).closest('tr');
                const isChecked = $(this).is(':checked');
                row.find('.txt-rma-qty, .sel-rma-reason').prop('disabled', !isChecked);
            });

            // Gửi phiếu RMA qua API
            $('#frmCustomerReturn').submit(function(e) {
                e.preventDefault();

                const selectedRows = $('.chk-rma:checked').closest('tr');
                if(selectedRows.length === 0) {
                    alert("Bạn chưa chọn sản phẩm nào để hoàn trả.");
                    return;
                }

                let itemsArray = [];
                selectedRows.each(function() {
                    // ĐÃ SỬA: Viết hoa chữ cái đầu của payload object để C# Model Binding đọc chuẩn xác
                    itemsArray.push({
                        ChiTietSanPhamId: $(this).data('id'),
                        SoLuongTra: parseInt($(this).find('.txt-rma-qty').val()),
                        LyDoKey: parseInt($(this).find('.sel-rma-reason').val())
                    });
                });

                $.ajax({
                    url: '/Account/SubmitReturnRequest',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify({
                        HoaDonId: $('#rmaOrderId').val(),
                        GhiChu: $('#rmaNote').val(),
                        Items: itemsArray
                    }),
                    success: function(res) {
                        alert(res.message);
                        $('#customerReturnModal').modal('hide');
                        location.reload(); // Tải lại trang để cập nhật thông tin
                    },
                    error: function(err) {
                        alert(err.responseJSON?.message || "Đã xảy ra lỗi hệ thống, vui lòng thử lại sau.");
                    }
                });
            });
        });
    </script>
}