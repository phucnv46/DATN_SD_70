@model DATN_70.Models.ViewModels.AccountProfileViewModel
@{
    ViewData["Title"] = "Tài khoản của tôi";
}

<div class="container my-5">
    <div class="row">
        <div class="col-md-3 mb-4">
            <div class="list-group shadow-sm border-0">
                <a href="/Account/Profile" class="list-group-item list-group-item-action active bg-dark border-dark">
                    <i class="bi bi-person me-2"></i> Tài khoản của tôi
                </a>
                <a href="/Account/Orders" class="list-group-item list-group-item-action">
                    <i class="bi bi-bag me-2"></i> Đơn hàng của tôi
                </a>
                <a href="/Account/Addresses" class="list-group-item list-group-item-action">
                    <i class="bi bi-geo-alt me-2"></i> Địa chỉ giao hàng
                </a>
                <a href="/Account/Password" class="list-group-item list-group-item-action">
                    <i class="bi bi-shield-lock me-2"></i> Đổi mật khẩu
                </a>
                <a href="/Account/Logout" class="list-group-item list-group-item-action text-danger border-top">
                    <i class="bi bi-box-arrow-right me-2"></i> Đăng xuất
                </a>
            </div>
        </div>

        <div class="col-md-9">
            <div class="card shadow-sm border-0 p-4 bg-white rounded">
                <div class="border-bottom pb-3 mb-4">
                    <h4 class="fw-bold text-uppercase">Hồ sơ của tôi</h4>
                    <p class="text-muted small mb-0">Quản lý và cập nhật thông tin tài khoản cá nhân của bạn.</p>
                </div>

                @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
                {
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        <i class="bi bi-check-circle-fill me-2"></i> @Model.StatusMessage
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                <form asp-controller="Account" asp-action="Profile" method="post" autocomplete="off">
                    @Html.AntiForgeryToken()

                    <input type="hidden" asp-for="TaiKhoanId" />
                    <input type="hidden" asp-for="KhachHangId" />

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-medium" asp-for="FullName">Họ và tên</label>
                            <input type="text" class="form-control" asp-for="FullName" placeholder="Nhập họ và tên" />
                            <span asp-validation-for="FullName" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-medium" asp-for="Phone">Số điện thoại</label>
                            <input type="tel" class="form-control" asp-for="Phone" placeholder="Nhập số điện thoại" />
                            <span asp-validation-for="Phone" class="text-danger small"></span>
                        </div>

                        <div class="col-md-12">
                            <label class="form-label fw-medium" asp-for="Email">Địa chỉ Email</label>
                            <input type="email" class="form-control" asp-for="Email" placeholder="name@example.com" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <div class="col-md-12">
                            <label class="form-label fw-medium text-muted">Địa chỉ nhận hàng mặc định</label>
                            <div class="p-3 bg-light rounded text-secondary small">
                                <i class="bi bi-geo-alt-fill me-1"></i> @Model.DefaultAddressText
                            </div>
                            <p class="text-muted mime-code small mt-1">
                                * Để thay đổi địa chỉ mặc định này, vui lòng truy cập mục <a href="/Account/Addresses" class="text-decoration-none">Địa chỉ giao hàng</a>.
                            </p>
                        </div>
                    </div>

                    <div class="mt-4 pt-3 border-top text-end">
                        <button type="submit" class="btn btn-dark px-4 fw-medium">Lưu thay đổi</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>