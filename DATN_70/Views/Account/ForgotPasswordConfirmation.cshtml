@{
    ViewData["Title"] = "Xác nhận quên mật khẩu";
}

<div class="container py-5 text-center">
    <h3 class="fw-bold mb-3">Yêu cầu đã được ghi nhận</h3>
    <p>Nếu email tồn tại trong hệ thống, link đặt lại mật khẩu sẽ được hiển thị bên dưới.</p>

    @if (ViewBag.ResetLink != null)
    {
        <div class="alert alert-success">
            <strong>Link đặt lại mật khẩu (giả lập gửi email):</strong><br />
            <a href="@ViewBag.ResetLink">@ViewBag.ResetLink</a>
        </div>
        <p class="text-muted small">Link có hiệu lực trong 15 phút.</p>
    }
    <a asp-action="Login" class="btn btn-dark rounded-3 mt-3">Quay lại đăng nhập</a>
</div>