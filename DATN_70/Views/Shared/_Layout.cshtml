@using Microsoft.AspNetCore.Http
@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
    var userId = Context.Session.GetString("UserId");
    var userEmail = Context.Session.GetString("UserEmail");
    var isAuthenticated = !string.IsNullOrWhiteSpace(userId);
    var pageTitle = ViewData["Title"]?.ToString() ?? "Winter Shop";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@pageTitle - Winter Shop</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Barlow:wght@400;500;600;700;800&family=Space+Grotesk:wght@500;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        /* TOP BAR MARQUEE */
        .store-topbar {
            background-color: #1e1e2d;
            color: #ffffff;
            font-size: 0.8rem;
            padding: 6px 0;
            overflow: hidden;
            white-space: nowrap;
        }

        .topbar-marquee {
            width: 100%;
            overflow: hidden;
        }

            .topbar-marquee span {
                display: inline-block;
                animation: marquee 30s linear infinite;
            }

        @@keyframes marquee {
            0% {
                transform: translateX(0);
            }

            100% {
                transform: translateX(-50%);
            }
        }

        /* HEADER MỚI */
        .store-header {
            background: #ffffff;
            box-shadow: 0 4px 20px rgba(0,0,0,0.06);
            position: sticky;
            top: 0;
            z-index: 1000;
        }

        .store-header-inner {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 12px 0;
        }

        .store-logo {
            font-family: 'Space Grotesk', sans-serif;
            font-weight: 700;
            font-size: 1.8rem;
            color: #1e1e2d;
            text-decoration: none;
            letter-spacing: -0.5px;
            transition: opacity 0.2s;
        }

            .store-logo:hover {
                opacity: 0.8;
                color: #1e1e2d;
            }

        .icon-button {
            color: #1e1e2d;
            transition: all 0.2s;
        }

            .icon-button:hover {
                color: #000;
                transform: scale(1.05);
            }
    </style>
</head>

<body class="store-body">
    <script>
        window.storeSession = {
            isAuthenticated: @(isAuthenticated ? "true" : "false"),
            userId: "@(userId ?? string.Empty)"
        };
    </script>
    <header class="store-header">
        <div class="store-topbar">
            <div class="topbar-marquee">
                <span>
                    Miễn phí giao hàng cho đơn từ 500.000đ &nbsp;&nbsp;•&nbsp;&nbsp;
                    Hỗ trợ đổi trả trong 7 ngày &nbsp;&nbsp;•&nbsp;&nbsp;
                    Miễn phí giao hàng cho đơn từ 500.000đ &nbsp;&nbsp;•&nbsp;&nbsp;
                    Hỗ trợ đổi trả trong 7 ngày
                </span>
            </div>
        </div>
        <div class="container store-header-inner">
            <a class="store-logo" asp-controller="Home" asp-action="Index">Winter Shop</a>

            <nav class="store-nav" aria-label="Danh mục chính">
                <div class="nav-item has-submenu">
                    <a class="nav-link" asp-controller="Home" asp-action="Products" asp-route-category="outerwear">Áo khoác ngoài</a>
                    <div class="nav-submenu">
                        <a asp-controller="Home" asp-action="Products" asp-route-search="Áo phao">Áo phao</a>
                        <a asp-controller="Home" asp-action="Products" asp-route-search="Áo da">Áo da</a>
                        <a asp-controller="Home" asp-action="Products" asp-route-search="Măng tô">Măng tô</a>
                    </div>
                </div>
                <div class="nav-item has-submenu">
                    <a class="nav-link" asp-controller="Home" asp-action="Products" asp-route-category="short-jacket">Áo khoác ngắn</a>
                    <div class="nav-submenu">
                        <a asp-controller="Home" asp-action="Products" asp-route-search="Áo khoác ngắn">Áo khoác ngắn</a>
                        <a asp-controller="Home" asp-action="Products" asp-route-search="Gile">Gile phao</a>
                    </div>
                </div>
                <div class="nav-item has-submenu">
                    <a class="nav-link" asp-controller="Home" asp-action="Products" asp-route-category="layering">Áo len layer</a>
                    <div class="nav-submenu">
                        <a asp-controller="Home" asp-action="Products" asp-route-search="Áo len">Áo len</a>
                        <a asp-controller="Home" asp-action="Products" asp-route-search="Hoodie">Hoodie</a>
                    </div>
                </div>
                <div class="nav-item has-submenu">
                    <a class="nav-link" asp-controller="Home" asp-action="Products" asp-route-category="heattech">Áo giữ nhiệt</a>
                    <div class="nav-submenu">
                        <a asp-controller="Home" asp-action="Products" asp-route-search="Áo giữ nhiệt">Áo giữ nhiệt</a>
                    </div>
                </div>
            </nav>

            <div class="store-actions">
                <div class="header-search">
                    <button id="headerSearchToggle" type="button" class="icon-button" aria-label="Tìm kiếm">
                        <i class="bi bi-search"></i>
                    </button>
                    <div class="header-search-panel">
                        <label class="visually-hidden" for="headerSearchInput">Tìm kiếm sản phẩm</label>
                        <input id="headerSearchInput" type="search" class="header-search-input" placeholder="Tìm kiếm sản phẩm..." />
                        <div id="headerSearchResults" class="header-search-results">
                            <div class="header-search-empty">Nhập tên sản phẩm để tìm.</div>
                        </div>
                    </div>
                </div>

                @if (!isAuthenticated)
                {
                    <a class="icon-button" asp-controller="Account" asp-action="Login" aria-label="Đăng nhập">
                        <i class="bi bi-person"></i>
                    </a>
                }
                else
                {
                    <div class="account-menu">
                        <button type="button" class="icon-button" aria-label="Tài khoản">
                            <i class="bi bi-person"></i>
                        </button>
                        <div class="account-dropdown">
                            <div class="account-dropdown-head">
                                <strong>@(string.IsNullOrWhiteSpace(userEmail) ? "Tài khoản" : userEmail)</strong>
                                <span>@(string.Equals(currentController, "Account", StringComparison.OrdinalIgnoreCase) ? "Khu vực thành viên" : "Mua sắm trực tuyến")</span>
                            </div>
                            <a asp-controller="Account" asp-action="Profile">Tài khoản của tôi</a>
                            <a asp-controller="Account" asp-action="Orders">Đơn hàng của tôi</a>
                            <a asp-controller="Account" asp-action="Addresses">Địa chỉ giao hàng</a>
                            <a asp-controller="Account" asp-action="Password">Đổi mật khẩu</a>
                            <a asp-controller="Account" asp-action="Logout">Đăng xuất</a>
                        </div>
                    </div>
                }

                <div class="cart-menu">
                    <a class="icon-button cart-trigger" asp-controller="Home" asp-action="Cart" aria-label="Giỏ hàng">
                        <i class="bi bi-bag"></i>
                        <span id="cartBadge" class="cart-badge">0</span>
                    </a>
                    <div class="cart-preview">
                        <div class="cart-preview-head">
                            <strong>Giỏ hàng</strong>
                            <span id="cartPreviewCount">0 sản phẩm</span>
                        </div>
                        <div id="cartPreviewItems" class="cart-preview-items">
                            <div class="cart-preview-empty">Giỏ hàng đang trống.</div>
                        </div>
                        <div class="cart-preview-actions">
                            <a class="btn btn-dark-soft" asp-controller="Home" asp-action="Cart">Xem giỏ hàng</a>
                            <a class="btn btn-brand" asp-controller="Home" asp-action="Checkout">Thanh toán</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <main class="store-main">
        @RenderBody()
    </main>

    <footer class="store-footer">
        <div class="container store-footer-grid">
            <div>
                <div class="store-footer-brand">Winter Shop</div>
                <p class="footer-copy">Thời trang mùa đông tập trung vào áo khoác, áo len layer và các mẫu mặc hàng ngày dễ phối.</p>
            </div>
            <div>
                <h4>Hỗ trợ</h4>
                <a href="#">Chính sách đổi trả</a>
                <a href="#">Chính sách bảo mật</a>
                <a href="#">Hướng dẫn mua hàng</a>
            </div>
            <div>
                <h4>Thanh toán</h4>
                <div class="footer-badges">
                    <span>VNPAY</span>
                    <span>Visa</span>
                    <span>COD</span>
                </div>
            </div>
            <div>
                <h4>Vận chuyển</h4>
                <div class="footer-badges">
                    <span>VNPost</span>
                    <span>GHTK</span>
                    <span>Freeship</span>
                </div>
            </div>
        </div>
    </footer>

    <div id="toastContainer" class="toast-container position-fixed top-0 end-0 p-3"></div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>