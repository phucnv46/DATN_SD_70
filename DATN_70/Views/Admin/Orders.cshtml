@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Quản lý hóa đơn & Đổi trả";
    <style>
        /* Ép nhãn trạng thái returned hiển thị nền xám nhẹ và màu chữ đen */
        .badge-returned {
            background-color: #f1f1f1 !important;
            color: #000000 !important;
            border: 1px solid #dee2e6 !important;
        }
    </style>
}

<div class="card p-4 bg-white">
    <div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-center gap-3 mb-4">
        <div>
            <h4 class="fw-bold text-dark mb-1">QUẢN LÝ TIẾN ĐỘ GIAO DỊCH VÀ ĐỔI TRẢ</h4>
            <p class="text-muted small mb-0">Giám sát quy trình duyệt đơn hàng và tiếp nhận điều phối các phiếu yêu cầu hoàn hàng từ khách hàng.</p>
        </div>
    </div>

    <ul class="nav nav-pills mb-4 p-1 bg-light rounded-3 shadow-sm style-tabs" id="orderMainTabs" role="tablist" style="max-width: 500px;">
        <li class="nav-item" role="presentation">
            <button class="nav-link active fw-semibold py-2" data-bs-toggle="tab" data-bs-target="#tab-orders-list" type="button" id="btn-tab-orders"><i class="bi bi-receipt me-2"></i>Hóa đơn bán hàng</button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link fw-semibold py-2" data-bs-toggle="tab" data-bs-target="#tab-returns-list" type="button" id="btn-tab-returns"><i class="bi bi-arrow-counterclockwise me-2"></i>Yêu cầu Đổi / Trả (RMA)</button>
        </li>
    </ul>

    <div class="tab-content">
        <div class="tab-pane fade show active" id="tab-orders-list" role="tabpanel">
            <div class="d-flex justify-content-end mb-3">
                <select id="statusFilter" class="form-select form-select-sm w-auto fw-medium">
                    <option value="all">Tất cả trạng thái</option>
                    <option value="pending">Chờ xác nhận</option>
                    <option value="confirmed">Đã xác nhận</option>
                    <option value="preparing">Đang chuẩn bị</option>
                    <option value="shipping">Đang giao</option>
                    <option value="success">Thành công</option>
                    <option value="cancelled">Đã hủy</option>
                    <option value="delivery_failed">Giao thất bại</option>
                </select>
            </div>
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 50px;">STT</th>
                            <th>Mã Hóa Đơn</th>
                            <th>Ngày Đặt</th>
                            <th>Khách Hàng</th>
                            <th>Số Điện Thoại</th>
                            <th>Tổng Tiền</th>
                            <th>Loại Đơn</th>
                            <th>Trạng Thái</th>
                            <th class="text-center">Hành Động</th>
                        </tr>
                    </thead>
                    <tbody id="orderTableBody"></tbody>
                </table>
                <div class="d-flex justify-content-between align-items-center mt-3">
                    <div>
                        <span class="small text-muted">
                            Hiển thị <span id="startRecord">0</span>-<span id="endRecord">0</span> trên tổng <span id="totalRecords">0</span>
                        </span>
                    </div>
                    <nav>
                        <ul class="pagination pagination-sm mb-0" id="pagination"></ul>
                    </nav>
                </div>
            </div>
        </div>

        <div class="tab-pane fade" id="tab-returns-list" role="tabpanel">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Mã Phiếu RMA</th>
                            <th>Mã Hóa Đơn</th>
                            <th>Ngày Yêu Cầu</th>
                            <th>Khách Hàng</th>
                            <th>Giá Trị Hoàn</th>
                            <th class="text-center">Trạng Thái Kho</th>
                            <th class="text-center">Hành Động</th>
                        </tr>
                    </thead>
                    <tbody id="returnsTableBody"></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="orderModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title fw-bold">CHI TIẾT ĐƠN HÀNG <span id="modalOrderId" class="text-primary"></span></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" id="modalOrderContent"></div>
            <div class="modal-footer bg-light d-flex justify-content-between align-items-center">
                <div id="modalActionButtons" class="d-flex gap-2"></div>
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Đóng lại</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="createReturnModal" tabindex="-1" data-bs-backdrop="static" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-warning-subtle">
                <h5 class="modal-title fw-bold text-warning-emphasis"><i class="bi bi-arrow-counterclockwise me-2"></i>LẬP PHIẾU ĐỔI TRẢ CHO ĐƠN: <span id="lblReturnOrderId"></span></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="frmCreateReturn">
                <input type="hidden" id="hidReturnOrderId" />
                <div class="modal-body">
                    <p class="text-muted small">Tick chọn sản phẩm khách hàng hoàn trả, nhập đúng số lượng thực tế nhận lại và chọn lý do tương ứng.</p>

                    <div class="table-responsive mb-3">
                        <table class="table table-bordered align-middle small">
                            <thead class="table-light">
                                <tr>
                                    <th style="width: 40px;">Chọn</th>
                                    <th>Tên Sản Phẩm / Phân Loại</th>
                                    <th style="width: 100px;">Giá mua</th>
                                    <th style="width: 100px;">SL Mua</th>
                                    <th style="width: 110px;">SL Hoàn *</th>
                                    <th>Lý do đổi trả *</th>
                                </tr>
                            </thead>
                            <tbody id="returnItemsTableBody"></tbody>
                        </table>
                    </div>

                    <div class="mb-0">
                        <label class="form-label small fw-bold">Ghi chú kiểm kho của Admin/Nhân viên</label>
                        <textarea class="form-control form-control-sm" id="txtReturnGhiChu" rows="2" placeholder="Ví dụ: Khách trả lại do mặc chật, hàng còn nguyên tem mác..."></textarea>
                    </div>
                </div>
                <div class="modal-footer bg-light">
                    <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Hủy bỏ</button>
                    <button type="submit" class="btn btn-warning btn-sm fw-bold text-dark px-4">Xác nhận Tạo phiếu</button>
                </div>
            </form>
        </div>
    </div>
</div>
<!-- Template in hóa đơn (ẩn) -->
<div id="invoicePrintArea" style="display: none;">
    <style>
        @@media print {
            body * {
                visibility: hidden;
            }

            #invoicePrintArea, #invoicePrintArea * {
                visibility: visible;
            }

            #invoicePrintArea {
                position: absolute;
                left: 0;
                top: 0;
                width: 100%;
                padding: 20px;
                font-family: 'Times New Roman', serif;
                color: #000;
            }
        }

        .invoice-header {
            text-align: center;
            margin-bottom: 20px;
        }

            .invoice-header h2 {
                margin: 0;
                font-size: 24px;
            }

            .invoice-header p {
                margin: 2px 0;
                font-size: 14px;
            }

        .invoice-info {
            display: flex;
            justify-content: space-between;
            margin-bottom: 15px;
            font-size: 13px;
        }

        .invoice-table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 15px;
        }

            .invoice-table th, .invoice-table td {
                border: 1px solid #000;
                padding: 6px 8px;
                text-align: left;
                font-size: 13px;
            }

            .invoice-table th {
                background-color: #f0f0f0;
            }

        .text-right {
            text-align: right;
        }

        .invoice-total {
            text-align: right;
            font-weight: bold;
            margin-top: 10px;
        }
    </style>
    <div id="invoiceContent">
        <!-- Nội dung sẽ được điền bằng JavaScript -->
    </div>
</div>
@section Scripts {
    <script>
        $(document).ready(function() {
            $('#menu-orders').addClass('active');
                    let currentPage = 1;
                    const pageSize = 10;
                    let allOrders = [];
            let currentFinalAmt = 0;
            // Khởi chạy load danh sách hóa đơn mặc định
            loadOrders('all');

            $('#statusFilter').change(function() {
                loadOrders($(this).val());
            });

            // Lắng nghe click chuyển Tab để load danh sách tương ứng
            $('#btn-tab-orders').on('shown.bs.tab', function() { loadOrders($('#statusFilter').val()); });
            $('#btn-tab-returns').on('shown.bs.tab', function() { loadReturnRequests(); });

            // 1. HÀM LOAD DANH SÁCH HÓA ĐƠN
                    function loadOrders(status) {
            $('#orderTableBody').html('<tr><td colspan="9" class="text-center py-4 text-muted"><div class="spinner-border spinner-border-sm me-2"></div>Đang tải dữ liệu...</td></tr>');
            $.get(`/api/admin/orders?status=${status}`, function(data) {
                allOrders = data;
                currentPage = 1;
                renderOrdersPage();
            });
        }

        function renderOrdersPage() {
            const start = (currentPage - 1) * pageSize;
            const end = Math.min(start + pageSize, allOrders.length);
            const pageData = allOrders.slice(start, end);

            let html = '';
            if(pageData.length === 0) {
                html = '<tr><td colspan="9" class="text-center py-4 text-muted">Không tìm thấy đơn hàng nào tương ứng.</td></tr>';
            } else {
                pageData.forEach((order, index) => {
                    const stt = start + index + 1;
                    html += `
                        <tr>
                            <td class="text-center small text-muted">${stt}</td>
                            <td class="fw-bold text-dark">${order.hoaDonId}</td>
                            <td class="small">${new Date(order.ngayTao).toLocaleString('vi-VN')}</td>
                            <td>${order.tenKhachHang}</td>
                            <td class="text-secondary">${order.soDienThoai}</td>
                            <td class="fw-bold text-danger">${order.thanhTien.toLocaleString('vi-VN')}đ</td>
                            <td><span class="badge bg-light text-dark border">${order.loaiGiaoDich}</span></td>
                            <td><span class="badge badge-${order.trangThaiKey} px-2 py-1 rounded">${order.trangThaiLabel}</span></td>
                            <td class="text-center">
                                <button class="btn btn-sm btn-dark px-3 rounded-pill btn-view-detail" data-id="${order.hoaDonId}">Xem chi tiết</button>
                            </td>
                        </tr>`;
                });
            }
            $('#orderTableBody').html(html);

            $('#startRecord').text(allOrders.length > 0 ? start + 1 : 0);
            $('#endRecord').text(end);
            $('#totalRecords').text(allOrders.length);

            const totalPages = Math.ceil(allOrders.length / pageSize);
            let paginationHtml = '';
            if (totalPages > 1) {
                paginationHtml += `<li class="page-item ${currentPage === 1 ? 'disabled' : ''}"><a class="page-link" href="#" data-page="${currentPage - 1}">«</a></li>`;
                for (let i = 1; i <= totalPages; i++) {
                    paginationHtml += `<li class="page-item ${i === currentPage ? 'active' : ''}"><a class="page-link" href="#" data-page="${i}">${i}</a></li>`;
                }
                paginationHtml += `<li class="page-item ${currentPage === totalPages ? 'disabled' : ''}"><a class="page-link" href="#" data-page="${currentPage + 1}">»</a></li>`;
            }
            $('#pagination').html(paginationHtml);
        }

            // 2. HÀM LOAD DANH SÁCH PHIẾU ĐỔI TRẢ (TAB RMA)
            function loadReturnRequests() {
                $('#returnsTableBody').html('<tr><td colspan="7" class="text-center py-4 text-muted"><div class="spinner-border spinner-border-sm me-2"></div>Đang rà soát phiếu RMA...</td></tr>');
                $.get('/api/admin/orders/returns', function(data) {
                    let html = '';
                    if(!data || data.length === 0) {
                        html = '<tr><td colspan="7" class="text-center py-4 text-muted">Chưa phát sinh yêu cầu đổi trả nào.</td></tr>';
                    } else {
                        data.forEach(rma => {
                            let badgeClass = rma.trangThai === 0 ? 'bg-warning text-dark' : (rma.trangThai === 1 ? 'bg-success text-white' : 'bg-danger text-white');
                                    let approveBtn = '';
        if (rma.trangThai === 0) {
            approveBtn = `
                <div class="d-flex gap-1 justify-content-center">
                    <button class="btn btn-sm btn-success px-2 py-1 btn-approve-return" data-id="${rma.phieuDoiTraID}"><i class="bi bi-check-lg"></i> Duyệt</button>
                    <button class="btn btn-sm btn-outline-danger px-2 py-1 btn-reject-return" data-id="${rma.phieuDoiTraID}"><i class="bi bi-x-lg"></i> Từ chối</button>
                </div>`;
        } else {
            approveBtn = `<span class="text-muted small">Hoàn tất</span>`;
        }

                            html += `
                                <tr>
                                    <td class="font-monospace small fw-bold text-secondary">${rma.phieuDoiTraID}</td>
                                    <td class="fw-bold text-dark">${rma.hoaDonID}</td>
                                    <td class="small">${new Date(rma.ngayTao).toLocaleString('vi-VN')}</td>
                                    <td class="fw-medium">${rma.tenKhachHang}</td>
                                    <td class="fw-bold text-primary">${rma.tongTienHoan.toLocaleString('vi-VN')}đ</td>
                                    <td class="text-center"><span class="badge ${badgeClass} px-2 py-1">${rma.trangThaiLabel}</span></td>
                                    <td class="text-center">${approveBtn}</td>
                                </tr>`;
                        });
                    }
                    $('#returnsTableBody').html(html);
                });
            }

            // 3. XEM CHI TIẾT HÓA ĐƠN VÀ THIẾT LẬP NÚT BẤM TIẾN TRÌNH
            $(document).on('click', '.btn-view-detail', function() {
                const orderId = $(this).data('id');
                $('#modalOrderId').text(orderId);
                $('#modalOrderContent').html('<div class="text-center py-5 text-muted"><div class="spinner-border mb-2"></div><p>Đang bóc tách dữ liệu đơn hàng...</p></div>');
                $('#orderModal').modal('show');

                $.get(`/api/admin/orders/${orderId}`, function(order) {
                    let buttonsHtml = '';
                    if (order.trangThaiKey === 'pending') {
                        buttonsHtml = `
                            <button class="btn btn-primary btn-sm fw-medium btn-process-order" data-action="next"><i class="bi bi-check-circle me-1"></i> Xác nhận đơn hàng</button>
                            <button class="btn btn-outline-danger btn-sm fw-medium btn-process-order" data-action="cancel"><i class="bi bi-x-circle me-1"></i> Hủy đơn</button>`;
                    } else if (order.trangThaiKey === 'confirmed') {
                        buttonsHtml = `
                            <button class="btn btn-info text-white btn-sm fw-medium btn-process-order" data-action="next"><i class="bi bi-box-seam me-1"></i> Tiến hành chuẩn bị hàng</button>
                            <button class="btn btn-outline-danger btn-sm fw-medium btn-process-order" data-action="cancel"><i class="bi bi-x-circle me-1"></i> Hủy đơn</button>`;
                    } else if (order.trangThaiKey === 'preparing') {
                        buttonsHtml = `
                            <button class="btn btn-sm text-white btn-process-order" style="background-color: #7239ea;" data-action="next"><i class="bi bi-truck me-1"></i> Bàn giao vận chuyển</button>
                            <button class="btn btn-outline-danger btn-sm fw-medium btn-process-order" data-action="cancel"><i class="bi bi-x-circle me-1"></i> Hủy đơn</button>`;
                    }
                                    else if (order.trangThaiKey === 'shipping') {
            buttonsHtml = `
                <button class="btn btn-success btn-sm fw-medium btn-process-order" data-action="next"><i class="bi bi-bag-check me-1"></i> Xác nhận thành công</button>
                <button class="btn btn-outline-danger btn-sm fw-medium btn-process-order" data-action="fail"><i class="bi bi-truck me-1"></i> Giao thất bại</button>
                <button class="btn btn-outline-secondary btn-sm fw-medium btn-process-order" data-action="reschedule"><i class="bi bi-clock-history me-1"></i> Hẹn giao lại</button>`;
        }   else if (order.trangThaiKey === 'shipping') {
                        buttonsHtml = `<button class="btn btn-success btn-sm fw-medium btn-process-order" data-action="next"><i class="bi bi-bag-check me-1"></i> Xác nhận thành công</button>`;
                    } else if (order.trangThaiKey === 'success') {
                        // KHI ĐƠN THÀNH CÔNG: Đẻ thêm nút Lập phiếu Đổi/Trả hàng kích hoạt RMA Module
                        buttonsHtml = `
                            <button class="btn btn-warning btn-sm fw-bold text-dark btn-trigger-return" data-id="${order.hoaDonId}">
                                <i class="bi bi-arrow-counterclockwise me-1"></i> Lập phiếu Đổi / Trả hàng
                            </button>
                            <span class="badge bg-success-soft text-success border p-2 ms-2 rounded-1 small fw-bold"><i class="bi bi-check-all me-1"></i> Đơn hoàn thành</span>`;
                    } else if (order.trangThaiKey === 'cancelled') {
                        buttonsHtml = `<span class="badge bg-danger-soft text-danger border p-2 rounded-1 small fw-bold"><i class="bi bi-x-circle-fill me-1"></i> Đơn đã bị hủy bỏ</span>`;
                    }
                    $('#modalActionButtons').html(buttonsHtml);
                            // Thêm nút In hóa đơn (chung cho mọi trạng thái, trừ đã hủy có thể ẩn)
        if (order.trangThaiKey !== 'cancelled') {
            buttonsHtml += `<button class="btn btn-outline-dark btn-sm fw-medium ms-2 btn-print-invoice" data-id="${order.hoaDonId}"><i class="bi bi-printer me-1"></i> In hóa đơn</button>`;
        }
        $('#modalActionButtons').html(buttonsHtml);
                            let itemsHtml = '';
        let stt = 1;
        order.chiTietSanPham.forEach(item => {
            itemsHtml += `
                <div class="d-flex justify-content-between align-items-center py-2 border-bottom small">
                    <div class="d-flex align-items-center gap-2" style="flex:1;">
                        <span class="badge bg-light text-dark border me-2">#${stt}</span>
                        <span class="badge bg-secondary me-2">${item.sanPhamID}</span>
                        <div>
                            <div class="fw-bold text-dark">${item.tenSanPham}</div>
                            <div class="text-muted">Phân loại: Size ${item.kichCo} / Màu ${item.mauSac} | Số lượng mua: ${item.soLuong}</div>
                        </div>
                    </div>
                    <div class="fw-medium">${item.donGia.toLocaleString('vi-VN')}đ</div>
                </div>`;
            stt++;
        });

                    let addressHtml = order.diaChiGiaoHang ? `
                        <div class="col-md-6 border-start">
                            <h6 class="fw-bold text-uppercase text-secondary mb-2">Thông tin nhận hàng</h6>
                            <div class="small"><strong>Người nhận:</strong> ${order.diaChiGiaoHang.tenNguoiNhan}</div>
                            <div class="small"><strong>Số điện thoại:</strong> ${order.diaChiGiaoHang.soDienThoaiNhan}</div>
                            <div class="small"><strong>Địa chỉ giao:</strong> ${order.diaChiGiaoHang.diaChiChiTiet}</div>
                        </div>` : '<div class="col-md-6 border-start text-muted small py-3">Đơn mua trực tiếp tại quầy bán hàng.</div>';

                    let content = `
                        <div class="row g-3 mb-4">
                            <div class="col-md-6">
                                <h6 class="fw-bold text-uppercase text-secondary mb-2">Thông tin tài khoản mua</h6>
                                <div class="small"><strong>Khách hàng:</strong> ${order.khachHang.ten}</div>
                                <div class="small"><strong>Email:</strong> ${order.khachHang.email}</div>
                                <div class="small"><strong>Số điện thoại:</strong> ${order.khachHang.soDienThoai}</div>
                            </div>
                            ${addressHtml}
                        </div>
                        <div class="mb-3">
                            <h6 class="fw-bold text-uppercase text-secondary mb-2">Danh sách sản phẩm đã đặt</h6>
                            ${itemsHtml}
                        </div>
                        <div class="text-end bg-light p-3 rounded">
                            <div class="small text-muted">Tổng tiền hàng gồm VAT: <strong>${order.tongTienVAT.toLocaleString('vi-VN')}đ</strong></div>
                            <div class="small text-muted border-bottom pb-1 mb-1">Giảm giá voucher: <strong>-${order.tongTienGiamGia.toLocaleString('vi-VN')}đ</strong></div>
                            <div class="fw-bold text-danger fs-5">Thành tiền thanh toán: ${order.thanhTien.toLocaleString('vi-VN')}đ</div>
                        </div>`;
                    $('#modalOrderContent').html(content);
                });
            });

            // 4. ĐIỀU PHỐI ĐƠN HÀNG MỘT CHIỀU (NÚT XÁC NHẬN/HỦY)
                    $(document).on('click', '.btn-process-order', function() {
            const orderId = $('#modalOrderId').text();
            const actionType = $(this).data('action');

            if (actionType === 'reschedule') {
                const reason = prompt("Nhập lý do hoặc thời gian hẹn giao lại:");
                if (!reason || reason.trim() === '') return;

                $.ajax({
                    url: `/api/admin/orders/${orderId}/status`,
                    type: 'PUT',
                    contentType: 'application/json',
                    data: JSON.stringify({ action: actionType, ghiChu: reason.trim() }),
                    success: function(res) {
                        alert(res.message);
                        $('#orderModal').modal('hide');
                        loadOrders($('#statusFilter').val());
                    },
                    error: function(err) { alert(err.responseJSON?.message || "Lỗi khi lưu ghi chú hẹn giao."); }
                });
                return;
            }

            const confirmMsg = actionType === 'cancel' ? "Bạn có chắc chắn muốn HỦY đơn hàng này không?" : "Xác nhận chuyển đơn hàng này sang trạng thái tiếp theo?";
            if(!confirm(confirmMsg)) return;

            $.ajax({
                url: `/api/admin/orders/${orderId}/status`,
                type: 'PUT',
                contentType: 'application/json',
                data: JSON.stringify({ action: actionType }),
                success: function() {
                    $('#orderModal').modal('hide');
                    loadOrders($('#statusFilter').val());
                },
                error: function(err) { alert(err.responseJSON?.message || "Lỗi xử lý tiến độ đơn hàng."); }
            });
        });
            // ==========================================
            // LOGIC XỬ LÝ EVENT MỚI: BẤM NÚT LẬP PHIẾU ĐỔI TRẢ
            // ==========================================
            $(document).on('click', '.btn-trigger-return', function() {
                const orderId = $(this).data('id');
                $('#orderModal').modal('hide'); // Ẩn modal chi tiết đơn hàng cũ đi

                $('#lblReturnOrderId').text(orderId);
                $('#hidReturnOrderId').val(orderId);
                $('#txtReturnGhiChu').val('');
                $('#returnItemsTableBody').empty();

                // Gọi API bóc tách mặt hàng để đổ lên form lập phiếu trả
                $.get(`/api/admin/orders/${orderId}`, function(order) {
                    let rowsHtml = '';
                    order.chiTietSanPham.forEach(item => {
                        rowsHtml += `
                            <tr class="row-return-item" data-sp-id="${item.chiTietSanPhamId}">
                                <td class="text-center">
                                    <input type="checkbox" class="form-check-input chk-return-select" style="cursor:pointer;" />
                                </td>
                                <td>
                                    <div class="fw-bold">${item.tenSanPham}</div>
                                    <small class="text-muted">Size: ${item.kichCo} | Màu: ${item.mauSac}</small>
                                </td>
                                <td class="fw-medium">${item.donGia.toLocaleString('vi-VN')}đ</td>
                                <td class="text-secondary text-center">${item.soLuong}</td>
                                <td>
                                    <input type="number" class="form-control form-control-sm txt-return-qty" min="1" max="${item.soLuong}" value="1" disabled />
                                </td>
                                <td>
                                    <select class="form-select form-select-sm sel-return-reason" disabled>
                                        <option value="1">Sai Kích cỡ / Màu sắc</option>
                                        <option value="0">Lỗi do Nhà sản xuất</option>
                                        <option value="2">Hệ thống giao thiếu hàng</option>
                                        <option value="3">Lý do Khác</option>
                                    </select>
                                </td>
                            </tr>`;
                    });
                    $('#returnItemsTableBody').html(rowsHtml);
                    $('#createReturnModal').modal('show'); // Mở bung siêu form lập phiếu trả
                });
            });

            // Khi người dùng tick/untick chọn sản phẩm hoàn trả thì mở khóa các input tương ứng
            $(document).on('change', '.chk-return-select', function() {
                const row = $(this).closest('tr');
                const isChecked = $(this).is(':checked');
                row.find('.txt-return-qty, .sel-return-reason').prop('disabled', !isChecked);
                if(isChecked) row.addClass('table-warning-subtle');
                else row.removeClass('table-warning-subtle');
            });

            // SUBMIT FORM TẠO PHIẾU ĐỔI TRẢ (POST PHIẾU CHỜ DUYỆT)
            $('#frmCreateReturn').submit(function(e) {
                e.preventDefault();

                const selectedRows = $('.chk-return-select:checked').closest('tr');
                if(selectedRows.length === 0) {
                    alert("Vui lòng tick chọn ít nhất một mặt hàng khách muốn hoàn trả!");
                    return;
                }

                let itemsArray = [];
                selectedRows.each(function() {
                    itemsArray.push({
                        chiTietSanPhamId: $(this).data('sp-id'),
                        soLuongTra: parseInt($(this).find('.txt-return-qty').val()),
                        lyDoKey: parseInt($(this).find('.sel-return-reason').val())
                    });
                });

                const payload = {
                    hoaDonId: $('#hidReturnOrderId').val(),
                    ghiChu: $('#txtReturnGhiChu').val(),
                    items: itemsArray
                };

                $.ajax({
                    url: '/api/admin/orders/returns',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify(payload),
                    success: function(res) {
                        alert(res.message);
                        $('#createReturnModal').modal('hide');
                        // Tự động gạt tab qua xem danh sách yêu cầu RMA đổi trả ngay lập tức
                        var triggerEl = document.querySelector('#btn-tab-returns');
                        bootstrap.Tab.getInstance(triggerEl).show();
                    },
                    error: function(err) { alert(err.responseJSON?.message || "Lỗi tạo yêu cầu đổi trả."); }
                });
            });

            // 5. BẤM NÚT DUYỆT HOÀN KHO: CỘNG THỰC TẾ SỐ LƯỢNG VÀO BẢNG CHITIETSANPHAM
            $(document).on('click', '.btn-approve-return', function() {
                const returnId = $(this).data('id');
                if(!confirm(`Xác nhận phê duyệt yêu cầu RMA [${returnId}]?\nHệ thống sẽ nhận lại hàng hoàn, đóng kho và cộng ngược lại số lượng tồn kho vật lý tự động.`)) return;

                const btn = $(this);
                btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm"></span>');

                $.ajax({
                    url: `/api/admin/orders/returns/${returnId}/approve`,
                    type: 'PUT',
                    success: function(res) {
                        alert(res.message);
                        loadReturnRequests(); // Nạp lại danh sách để đổi màu trạng thái
                    },
                    error: function(err) {
                        alert(err.responseJSON?.message || "Lỗi xử lý duyệt phiếu hoàn kho.");
                        btn.prop('disabled', false).html('<i class="bi bi-check-lg"></i> Duyệt hoàn kho');
                    }
                });
            });
                    // SỰ KIỆN BẤM NÚT TỪ CHỐI PHIẾU RMA ĐỔI TRẢ
        $(document).on('click', '.btn-reject-return', function() {
            const returnId = $(this).data('id');
            if(!confirm(`Xác nhận TỪ CHỐI yêu cầu đổi trả mã [${returnId}]?`)) return;

            $.ajax({
                url: `/api/admin/orders/returns/${returnId}/reject`,
                type: 'PUT',
                success: function(res) {
                    alert(res.message);
                    loadReturnRequests(); // Tải lại danh sách tab RMA
                },
                error: function() { alert("Lỗi hệ thống khi từ chối phiếu."); }
            });

        });
                // Xử lý nút In hóa đơn
        $(document).on('click', '.btn-print-invoice', function() {
            const orderId = $(this).data('id');
            // Lấy dữ liệu đang hiển thị trong modal
            const customerName = $('#modalOrderContent').find('.small:contains("Khách hàng:")').text().replace('Khách hàng:', '').trim();
            const customerPhone = $('#modalOrderContent').find('.small:contains("Số điện thoại:")').first().text().replace('Số điện thoại:', '').trim();
            const address = $('#modalOrderContent').find('.small:contains("Địa chỉ giao:")').text().replace('Địa chỉ giao:', '').trim() || 'Mua tại quầy';
            const orderTime = $('#modalOrderContent').find('.small:contains("Ngày đặt:")').text().replace('Ngày đặt:', '').trim() || new Date().toLocaleString('vi-VN');
            const totalVAT = $('#modalOrderContent').find('.small:contains("Tổng tiền hàng gồm VAT:")').text().replace('Tổng tiền hàng gồm VAT:', '').trim();
            const discount = $('#modalOrderContent').find('.small:contains("Giảm giá voucher:")').text().replace('Giảm giá voucher:', '').trim();
            const finalTotal = $('#modalOrderContent').find('.fw-bold.text-danger.fs-5').text().trim();

            // Lấy danh sách sản phẩm
            let itemsHtml = '';
            let stt = 1;
                    $('#modalOrderContent').find('.d-flex.justify-content-between.align-items-center.py-2.border-bottom.small').each(function() {
            const maSP = $(this).find('.badge.bg-secondary').text(); // Lấy mã SP từ badge
            const name = $(this).find('.fw-bold.text-dark').text();
            const variant = $(this).find('.text-muted').text().replace('Phân loại:', '').trim();
            const qty = $(this).find('.text-muted').text().match(/Số lượng mua: (\d+)/)?.[1] || '1';
            const price = $(this).find('.fw-medium').text();
            itemsHtml += `
                <tr>
                    <td>${stt}</td>
                    <td>${maSP}</td>
                    <td>${name}</td>
                    <td>${variant}</td>
                    <td>${qty}</td>
                    <td class="text-right">${price}</td>
                </tr>`;
            stt++;
        });

            // Điền vào template
            const printContent = `
                <div class="invoice-header">
                    <h2>WINTER FASHION SHOP</h2>
                    <p>Địa chỉ: Sơn Tây, Hà Nội, Việt Nam</p>
                    <p>Hotline: 098.765.4321</p>
                    <h3>HÓA ĐƠN BÁN HÀNG</h3>
                    <p>Mã HĐ: ${orderId}</p>
                    <p>Ngày: ${orderTime}</p>
                </div>
                <div class="invoice-info">
                    <div><strong>Khách hàng:</strong> ${customerName}</div>
                    <div><strong>Điện thoại:</strong> ${customerPhone}</div>
                    <div><strong>Địa chỉ:</strong> ${address}</div>
                </div>
                <table class="invoice-table">
                            <thead>
            <tr>
                <th>STT</th>
                <th>Mã SP</th>
                <th>Tên sản phẩm</th>
                <th>Phân loại</th>
                <th>SL</th>
                <th class="text-right">Đơn giá</th>
            </tr>
        </thead>
                    <tbody>
                        ${itemsHtml}
                    </tbody>
                </table>
                <div class="invoice-total">
                    <p>Tổng tiền hàng (gồm VAT): ${totalVAT}</p>
                    <p>Giảm giá: ${discount}</p>
                    <h3>Thành tiền: ${finalTotal}</h3>
                </div>
                <p style="text-align: center; font-style: italic;">Cảm ơn quý khách đã mua hàng!</p>
            `;

            $('#invoiceContent').html(printContent);
            $('#invoicePrintArea').show();
            window.print();
            $('#invoicePrintArea').hide();
                    $(document).on('click', '#pagination .page-link', function(e) {
            e.preventDefault();
            const page = parseInt($(this).data('page'));
            if (page && page !== currentPage && page >= 1 && page <= Math.ceil(allOrders.length / pageSize)) {
                currentPage = page;
                renderOrdersPage();
                $('html, body').animate({ scrollTop: $('#orderTableBody').offset().top - 100 }, 200);
            }
        });
        });
        });
    </script>
    <style>
        .badge-delivery_failed {
            background-color: #fff3cd !important;
            color: #856404 !important;
            border: 1px solid #ffc107 !important;
        }
    </style>
}