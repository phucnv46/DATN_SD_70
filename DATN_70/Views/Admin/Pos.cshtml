@{
    Layout = null; // Khóa hoàn toàn layout mặc định để chiếm trọn vẹn không gian hiển thị 100% màn hình quầy
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Hệ Thống Bán Hàng Tại Quầy - POS V1.0</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.min.css" />

    <style>
        body {
            background-color: #f4f6f9;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            overflow: hidden; /* Khóa cuộn trang tổng để chia khung cuộn độc lập */
            height: 100vh;
        }

        .pos-header {
            height: 50px;
            background-color: #1e293b;
            color: #fff;
        }

        .pos-workspace {
            height: calc(100vh - 50px);
        }

        .product-sidebar {
            height: 100%;
            overflow-y: auto;
            border-right: 1px solid #dee2e6;
        }

        .checkout-panel {
            height: 100%;
            background-color: #ffffff;
            display: flex;
            flex-direction: column;
        }

        .cart-table-wrapper {
            flex-grow: 1;
            overflow-y: auto;
            max-height: calc(100vh - 460px);
        }

        .product-card {
            cursor: pointer;
            transition: all 0.2s ease-in-out;
            border: 1px solid #e2e8f0;
        }

            .product-card:hover {
                transform: translateY(-2px);
                box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
                border-color: #cbd5e1;
            }

        .tab-waiting.active {
            background-color: #0ea5e9 !important;
            color: #ffffff !important;
            font-weight: bold;
        }

        .search-results-dropdown {
            position: absolute;
            z-index: 1050;
            width: 100%;
            max-height: 200px;
            overflow-y: auto;
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
        }

        /* 🖨️ ĐỊNH DẠNG CSS PHỤC VỤ IN HÓA ĐƠN NHIỆT ẢO KHỔ K80 (80mm) */
        @@media print {
            body * {
                visibility: hidden;
            }

            #invoice-print-template, #invoice-print-template * {
                visibility: visible;
            }

            #invoice-print-template {
                position: absolute;
                left: 0;
                top: 0;
                width: 80mm;
                font-size: 12px;
                line-height: 1.4;
                color: #000;
                background: #fff;
                padding: 2mm;
            }

            .text-center {
                text-align: center;
            }

            .text-end {
                text-align: right;
            }

            .border-dashed {
                border-top: 1px dashed #000;
                margin: 5px 0;
            }
        }
    </style>
</head>
<body>

    <div class="pos-header d-flex justify-content-between align-items-center px-3 shadow-sm">
        <div>
            <a href="/Admin/Orders" class="btn btn-sm btn-outline-light rounded-pill px-3 fw-medium" onclick="return confirm('Xác nhận thoát không gian bán hàng để trở về Bảng điều khiển?')">
                <i class="bi bi-arrow-left-circle me-1"></i> Trở về điều khiển
            </a>
            <span class="ms-3 border-start border-secondary ps-3 text-warning fw-bold small"><i class="bi bi-cpu-fill me-1"></i> PHÂN HỆ THU NGÂN POS V1.0</span>
        </div>

        <div class="d-flex gap-1" id="posTabsHeaders">
        </div>

        <div class="d-flex align-items-center gap-3 text-light small">
            <div><i class="bi bi-person-badge me-1"></i> Thu ngân: <strong id="lblCashierName">NV_TEMP_01</strong></div>
            <div class="border-start border-secondary ps-3"><i class="bi bi-clock me-1"></i> <span id="lblLiveClock">00:00:00</span></div>
        </div>
    </div>

    <div class="container-fluid pos-workspace">
        <div class="row h-100">

            <div class="col-md-7 col-lg-8 p-3 product-sidebar">
                <div class="row g-2 mb-3 align-items-center">
                    <div class="col-md-6 position-relative">
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0 text-muted"><i class="bi bi-search"></i></span>
                            <input type="text" class="form-control border-start-0 shadow-none ps-0" id="txtProductSearch" placeholder="Tìm tên sản phẩm hoặc Quét mã vạch (SKU)..." autocomplete="off" />
                        </div>
                    </div>
                    <div class="col-md-6 text-end">
                        <span class="badge bg-secondary px-3 py-2 rounded-pill small"><i class="bi bi-qr-code-scan me-1"></i> Chế độ máy quét mã vạch Đang bật</span>
                    </div>
                </div>

                <div class="row g-3" id="posProductGrid">
                </div>
            </div>

            <div class="col-md-5 col-lg-4 p-0 checkout-panel shadow-sm">

                <div class="p-3 border-bottom bg-light">
                    <label class="form-label small fw-bold text-secondary mb-1"><i class="bi bi-person-fill me-1"></i> KHÁCH HÀNG MUA TẠI QUẦY</label>
                    <div class="input-group position-relative">
                        <input type="text" class="form-control form-control-sm shadow-none" id="txtCustomerSearch" placeholder="Nhập Tên hoặc SĐT để tìm khách quen..." autocomplete="off" />
                        <button class="btn btn-sm btn-dark px-3" type="button" data-bs-toggle="modal" data-bs-target="#modalQuickAddCustomer" title="Thêm nhanh khách hàng mới">
                            <i class="bi bi-person-plus-fill"></i> Thêm nhanh
                        </button>
                        <div class="list-group search-results-dropdown d-none" id="customerSearchResults"></div>
                    </div>
                    <div id="selectedCustomerBadge" class="mt-2 small text-primary fw-medium d-none">
                        <i class="bi bi-check2-circle"></i> Đang chọn: <span id="lblSelectedCustomer">Khách lẻ</span>
                        <button class="btn btn-xs p-0 text-danger ms-2 border-0 bg-transparent" id="btnRemoveSelectedCustomer" title="Bỏ chọn khánh hàng"><i class="bi bi-x-circle-fill"></i></button>
                    </div>
                </div>

                <div class="cart-table-wrapper p-2">
                    <table class="table table-sm align-middle small table-hover mb-0">
                        <tbody id="cartItemsBody">
                        </tbody>
                    </table>
                </div>

                <div class="p-3 border-top mt-auto bg-light-subtle">
                    <div class="d-flex justify-content-between mb-2 small text-secondary">
                        <span>Tổng tiền hàng:</span>
                        <span class="fw-medium text-dark" id="lblTotalCartPrice">0 đ</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2 small text-secondary">
                        <span>Thuế giá trị gia tăng (VAT):</span>
                        <span class="fw-medium text-dark" id="lblTotalVatPrice">0 đ</span>
                    </div>

                    <div class="input-group input-group-sm mb-3">
                        <span class="input-group-text bg-white text-muted"><i class="bi bi-ticket-perforated"></i></span>
                        <input type="text" class="form-control shadow-none" id="txtVoucherCode" placeholder="Nhập mã ưu đãi giảm giá..." />
                        <button class="btn btn-outline-dark" type="button" id="btnApplyVoucher">Áp dụng</button>
                    </div>
                    <div class="d-flex justify-content-between mb-2 small text-secondary d-none" id="boxDiscount">
                        <span>Chiết khấu Voucher:</span>
                        <span class="fw-bold text-success" id="lblVoucherDiscount">-0 đ</span>
                    </div>

                    <hr class="my-2" />
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <span class="fw-bold text-dark fs-6">TỔNG THANH TOÁN:</span>
                        <span class="fw-extrabold text-danger fs-4" id="lblFinalPrice">0 đ</span>
                    </div>

                    <div class="row g-2 mb-3">
                        <div class="col-6">
                            <input type="radio" class="btn-check" name="paymentType" id="payCash" value="0" checked autocomplete="off" />
                            <label class="btn btn-sm btn-outline-secondary w-100 py-2 fw-medium shadow-none" for="payCash"><i class="bi bi-cash-coin me-1"></i> TIỀN MẶT</label>
                        </div>
                        <div class="col-6">
                            <input type="radio" class="btn-check" name="paymentType" id="payQR" value="1" autocomplete="off" />
                            <label class="btn btn-sm btn-outline-secondary w-100 py-2 fw-medium shadow-none" for="payQR"><i class="bi bi-qr-code me-1"></i> CHUYỂN KHOẢN QR</label>
                        </div>
                    </div>

                    <div id="cashCalculationBox" class="row g-2 mb-3">
                        <div class="col-6">
                            <input type="number" class="form-control form-control-sm" id="numCustomerCash" placeholder="Tiền khách đưa..." min="0" />
                        </div>
                        <div class="col-6 d-flex align-items-center ps-2 small text-muted">
                            <span>Tiền thừa: <strong class="text-primary" id="lblRefundCash">0 đ</strong></span>
                        </div>
                    </div>

                    <button type="button" class="btn btn-success w-100 py-3 fw-bold rounded-3 text-uppercase shadow-sm" id="btnCompletePOSCheckout">
                        <i class="bi bi-printer-fill me-2"></i> Xác nhận thanh toán & In hóa đơn
                    </button>
                </div>

            </div>
        </div>
    </div>

    <div class="modal fade" id="modalQuickAddCustomer" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header bg-dark text-white">
                    <h5 class="modal-title small fw-bold"><i class="bi bi-person-plus-fill me-2"></i>THÊM NHANH KHÁCH HÀNG MỚI</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-toggle="modal" data-bs-target="#modalQuickAddCustomer"></button>
                </div>
                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label class="form-label small fw-medium">Họ và tên khách hàng <span class="text-danger">*</span></label>
                        <input type="text" class="form-control shadow-none" id="txtNewCustomerName" placeholder="Ví dụ: Phan Tuấn Ngọc" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-medium">Số điện thoại liên hệ <span class="text-danger">*</span></label>
                        <input type="tel" class="form-control shadow-none" id="txtNewCustomerPhone" placeholder="Ví dụ: 0987654321" />
                    </div>
                </div>
                <div class="modal-footer bg-light border-top-0">
                    <button type="button" class="btn btn-secondary btn-sm px-3 rounded-pill" data-bs-dismiss="modal">Hủy bỏ</button>
                    <button type="button" class="btn btn-dark btn-sm px-4 rounded-pill" id="btnSaveQuickCustomer">Lưu khách hàng</button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal fade" id="modalQRCode" tabindex="-1" data-bs-backdrop="static" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header bg-dark text-white py-2">
                    <h6 class="modal-title fw-bold"><i class="bi bi-qr-code-scan me-2"></i>QUÉT MÃ THANH TOÁN HÓA ĐƠN</h6>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" title="Hủy thanh toán"></button>
                </div>
                <div class="modal-body p-0 text-center bg-light" style="height: 550px;">
                    <iframe id="iframePayOS" src="" width="100%" height="100%" frameborder="0"></iframe>
                </div>
                <div class="modal-footer bg-light justify-content-between align-items-center py-2">
                    <span class="text-danger small fw-bold"><i class="bi bi-bell-fill"></i> Chú ý: Chỉ in hóa đơn khi điện thoại báo "Ting Ting"!</span>
                    <div>
                        <button type="button" class="btn btn-secondary btn-sm px-3 rounded-pill" data-bs-dismiss="modal">Đóng</button>
                        <button type="button" class="btn btn-success btn-sm px-4 rounded-pill fw-bold" id="btnConfirmQRPaid">
                            <i class="bi bi-check-circle-fill me-1"></i> Đã thu tiền & In Hóa Đơn
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div id="invoice-print-template" class="d-none">
        <div class="text-center">
            <h4 style="margin: 0; font-weight: bold; text-transform: uppercase;">WINTER FASHION SHOP</h4>
            <p style="margin: 2px 0; font-size: 11px;">Địa chỉ: Sơn Tây, Hà Nội, Việt Nam</p>
            <p style="margin: 2px 0; font-size: 11px;">Hotline: 098.765.4321</p>
            <h5 style="margin: 10px 0 5px 0; font-weight: bold; text-transform: uppercase;">BIÊN LAI THANH TOÁN CHỢ QUẦY</h5>
            <p style="margin: 0; font-size: 10px;" id="printOrderTime">Ngày: dd/MM/yyyy HH:mm</p>
            <p style="margin: 2px 0; font-size: 10px;" id="printInvoiceId">Mã HĐ: POSXXXXXXXX</p>
        </div>
        <div class="border-dashed"></div>
        <div style="font-size: 11px; margin-bottom: 5px;">
            <div><strong>Thu ngân:</strong> <span id="printCashier">NV_TEMP_01</span></div>
            <div><strong>Khách hàng:</strong> <span id="printCustomer">Khách lẻ</span></div>
        </div>
        <div class="border-dashed"></div>
        <table style="width: 100%; font-size: 11px; border-collapse: collapse;">
            <thead>
                <tr style="border-bottom: 1px dashed #000;">
                    <th style="text-align: left;">Sản phẩm</th>
                    <th style="text-align: center; width: 30px;">SL</th>
                    <th style="text-align: right; width: 70px;">Thành tiền</th>
                </tr>
            </thead>
            <tbody id="printInvoiceItemsBody"></tbody>
        </table>
        <div class="border-dashed"></div>
        <div style="font-size: 11px;">
            <div class="d-flex justify-content-between"><span>Cộng tiền hàng:</span><span id="printTotalGoods">0 đ</span></div>
            <div class="d-flex justify-content-between"><span>Thuế VAT:</span><span id="printTotalVat">0 đ</span></div>
            <div class="d-flex justify-content-between"><span>Giảm giá Voucher:</span><span id="printDiscount">0 đ</span></div>
            <div class="d-flex justify-content-between" style="font-weight: bold; font-size: 13px;"><span>TỔNG CỘNG:</span><span id="printFinalAmount">0 đ</span></div>
        </div>
        <div class="border-dashed"></div>
        <div class="text-center" style="font-size: 11px; margin-top: 10px; font-style: italic;">
            Cảm ơn Quý khách đã mua sắm tại Winter Fashion!<br />
            Mọi thắc mắc đổi trả vui lòng giữ lại hóa đơn trong vòng 7 ngày.
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        // 1. KHỞI TẠO CẤU TRÚC MẠNG TAB ĐỘNG (BẮT ĐẦU BẰNG 1 TAB DUY NHẤT)
        let posTabs = [];
        let activeTabIdx = 0; // Chỉ mục tab đang làm việc
        let localProductsCache = []; // Bộ nhớ cache sản phẩm

        // Hàm tạo một đối tượng cấu trúc tab hóa đơn rỗng mới
        function createNewTabObject(name) {
            return {
                tabName: name,
                customerId: 'KH000000',
                customerName: 'Khách lẻ',
                customerPhone: '0000000000',
                items: [], // Giỏ hàng chi tiết
                voucherId: '',
                voucherCode: '',
                discountAmount: 0,
                note: ''
            };
        }

        // Bật màn hình: Khởi tạo duy nhất 1 tab đầu tiên thay vì đổ cả 5 tab như trước
        function initPOSSystemTabs() {
            posTabs.push(createNewTabObject("Hóa đơn 1"));
            renderTabsHeaders();
            loadActiveTabToSidebarCart();
        }

        // Vẽ hệ thống nút Tab động và nút Dấu Cộng (+) lên thanh Header điều hướng
        function renderTabsHeaders() {
            let html = '';
            posTabs.forEach((tab, index) => {
                let badgeItemCount = tab.items.length > 0 ? `<span class="badge bg-danger ms-1" style="font-size:0.65rem;">${tab.items.length}</span>` : '';

                // NÚT ĐÓNG TAB (DẤU X): Chỉ hiển thị khi quầy đang mở từ 2 hóa đơn chờ trở lên
                let closeBtn = posTabs.length > 1
                    ? `<i class="bi bi-x-lg ms-2 btn-close-tab text-white-50" style="font-size: 0.65rem; cursor: pointer; transition: color 0.2s;" onclick="closePosTab(event, ${index})" title="Đóng hóa đơn này"></i>`
                    : '';

                html += `<button class="btn btn-sm btn-dark tab-waiting py-1 px-3 d-inline-flex align-items-center ${index === activeTabIdx ? 'active' : ''}" onclick="switchActiveTab(${index})">
                            <i class="bi bi-file-earmark-text me-1"></i> ${tab.tabName}${badgeItemCount}
                            ${closeBtn}
                         </button>&nbsp;`;
            });

            // NÚT DẤU CỘNG (+): Chỉ hiển thị khi tổng số tab đang mở nhỏ hơn giới hạn 5 tab
            if (posTabs.length < 5) {
                html += `<button class="btn btn-sm btn-success rounded-circle ms-1" style="width: 28px; height: 28px; padding: 0; display: inline-flex; align-items: center; justify-content: center;" onclick="addNewPosTab()" title="Mở thêm hóa đơn mới (Tối đa 5)">
                            <i class="bi bi-plus-lg"></i>
                         </button>`;
            }
            $('#posTabsHeaders').html(html);
        }

        // Thao tác bấm nút dấu (+) để sinh thêm 1 đơn hàng mới
        function addNewPosTab() {
            if (posTabs.length >= 5) {
                alert("Hệ thống giới hạn tối đa phục vụ 5 hóa đơn chờ cùng lúc tại quầy.");
                return;
            }

            // Tính toán số thứ tự hóa đơn tiếp theo để đặt tên (tránh trùng lặp khi đóng/mở xen kẽ)
            let nextNum = 1;
            while(posTabs.some(t => t.tabName === `Hóa đơn ${nextNum}`)) {
                nextNum++;
            }

            // Tạo và đẩy tab mới vào mảng quản lý
            posTabs.push(createNewTabObject(`Hóa đơn ${nextNum}`));

            // Tự động chuyển tiêu điểm (Focus) sang ngay tab mới vừa tạo
            activeTabIdx = posTabs.length - 1;

            renderTabsHeaders();
            loadActiveTabToSidebarCart();
            $('#txtVoucherCode').val('');
            $('#txtCustomerSearch').val('');
        }

        // Thao tác bấm dấu (X) để đóng/hủy một tab hóa đơn chờ bất kỳ
        function closePosTab(event, index) {
            event.stopPropagation(); // Ngăn sự kiện click lan ra ngoài gây nhảy tab nhầm

            let tab = posTabs[index];
            // Nếu tab đang có hàng, bắt buộc phải hỏi ý kiến thu ngân để tránh mất dữ liệu
            if (tab.items.length > 0) {
                if (!confirm(`Cảnh báo: Hóa đơn [${tab.tabName}] đang có sản phẩm trong giỏ hàng. Bạn có chắc chắn muốn xóa bỏ và đóng tab này không?`)) {
                    return;
                }
            }

            posTabs.splice(index, 1); // Xóa khỏi mảng

            // Cân đối lại vị trí activeTabIdx sau khi xóa tab để tránh lỗi tràn mảng dữ liệu JavaScript
            if (activeTabIdx >= posTabs.length) {
                activeTabIdx = posTabs.length - 1;
            } else if (activeTabIdx === index) {
                if(activeTabIdx < 0) activeTabIdx = 0;
            }

            renderTabsHeaders();
            loadActiveTabToSidebarCart();

            // Đồng bộ lại ô nhập voucher của tab được chuyển đến
            if(posTabs[activeTabIdx]) {
                $('#txtVoucherCode').val(posTabs[activeTabIdx].voucherCode);
            }
        }

        // Chuyển đổi qua lại giữa các Tab đơn hàng
        function switchActiveTab(tabIndex) {
            activeTabIdx = tabIndex;
            renderTabsHeaders();
            loadActiveTabToSidebarCart();
            $('#txtVoucherCode').val(posTabs[activeTabIdx].voucherCode);
            $('#txtCustomerSearch').val('');
        }

        // 2. TẢI DỮ LIỆU SẢN PHẨM TỪ BACKEND KHO VẬT LÝ
        function loadProductsFromWarehouse() {
            $.ajax({
                url: '/api/admin/pos/products',
                type: 'GET',
                success: function(res) {
                    localProductsCache = res;
                    renderProductsGrid(res);
                },
                error: function() { alert("Không thể đồng bộ danh sách sản phẩm từ kho vật lý."); }
            });
        }

        function renderProductsGrid(products) {
            let html = '';
            if(products.length === 0) {
                html = `<div class="col-12 text-center text-muted py-5"><i class="bi bi-exclamation-circle fs-3"></i><br>Không có sản phẩm nào khả dụng hoặc còn tồn kho.</div>`;
            } else {
                products.forEach(p => {
                    let imgUrl = p.hinhAnhUrl ? p.hinhAnhUrl : '/images/default-product.png';
                    html += `
                        <div class="col-sm-6 col-md-4 col-lg-3">
                            <div class="card h-100 product-card shadow-xs" onclick="addProductToActiveCart('${p.chiTietSanPhamID}')">
                                <div class="position-relative bg-light text-center d-flex align-items-center justify-content-center border-bottom" style="height: 120px; overflow: hidden; border-top-left-radius: 7px; border-top-right-radius: 7px;">
                                    <img src="${imgUrl}" class="img-fluid" alt="${p.tenSanPham}" style="max-height: 100%; max-width: 100%; object-fit: cover;" onerror="this.src='/images/default-product.png';" />
                                </div>
                                <div class="card-body p-2 d-flex flex-column justify-content-between">
                                    <div>
                                        <span class="badge bg-light text-dark border small mb-1">${p.sku}</span>
                                        <h6 class="card-title small fw-bold text-dark mb-1 text-truncate" title="${p.tenSanPham}">${p.tenSanPham}</h6>
                                        <div class="text-muted" style="font-size: 0.75rem;">Cỡ: ${p.kichCo} | Màu: ${p.mauSac}</div>
                                    </div>
                                    <div class="d-flex justify-content-between align-items-center mt-2">
                                        <span class="text-danger fw-bold small">${p.giaBan.toLocaleString('vi-VN')} đ</span>
                                        <span class="badge bg-success-subtle text-success rounded-1" style="font-size:0.7rem;">Kho: ${p.soLuongTonKho}</span>
                                    </div>
                                </div>
                            </div>
                        </div>`;
                });
            }
            $('#posProductGrid').html(html);
        }

        // Thêm sản phẩm được click vào giỏ hàng của Tab đang hiển thị
        function addProductToActiveCart(chiTietId) {
            let activeTab = posTabs[activeTabIdx];
            let product = localProductsCache.find(p => p.chiTietSanPhamID == chiTietId);
            if(!product) return;

            let existingItem = activeTab.items.find(item => item.id === chiTietId);
            if(existingItem) {
                if(existingItem.qty >= product.soLuongTonKho) {
                    alert(`Sản phẩm [${product.tenSanPham}] đã đạt giới hạn tồn kho vật lý tối đa tại quầy (${product.soLuongTonKho}).`);
                    return;
                }
                existingItem.qty += 1;
            } else {
                activeTab.items.push({
                    id: product.chiTietSanPhamID,
                    name: product.tenSanPham,
                    sku: product.sku,
                    variant: `${product.kichCo} / ${product.mauSac}`,
                    price: product.giaBan,
                    vatRate: product.mucVAT,
                    qty: 1,
                    stock: product.soLuongTonKho
                });
            }
            renderTabsHeaders();
            loadActiveTabToSidebarCart();
        }

        // Đổ dữ liệu giỏ hàng của Tab hiện tại lên thanh Sidebar bên phải
        function loadActiveTabToSidebarCart() {
            let activeTab = posTabs[activeTabIdx];
            if(!activeTab) return;

            // Xử lý Badge hiển thị khách hàng
            if(activeTab.customerId !== 'KH000000') {
                $('#lblSelectedCustomer').text(`${activeTab.customerName} (${activeTab.customerPhone})`);
                $('#selectedCustomerBadge').removeClass('d-none');
            } else {
                $('#selectedCustomerBadge').addClass('d-none');
            }

            let html = '';
            let totalCartPrice = 0;
            let totalVatPrice = 0;

            if(activeTab.items.length === 0) {
                html = `<tr><td colspan="4" class="text-center py-5 text-muted"><i class="bi bi-cart-x fs-4"></i><br>Giỏ hàng trống. Bấm chọn hàng minh họa bên trái.</td></tr>`;
            } else {
                activeTab.items.forEach((item, index) => {
                    let itemTotalPrice = item.price * item.qty;
                    let itemTotalVat = (itemTotalPrice * item.vatRate / 100);
                    totalCartPrice += itemTotalPrice;
                    totalVatPrice += itemTotalVat;

                    html += `
                        <tr style="border-bottom:1px solid #f1f5f9;">
                            <td style="width: 50%;">
                                <div class="fw-bold text-dark text-truncate" style="max-width:140px;">${item.name}</div>
                                <div class="text-muted" style="font-size:0.7rem;">${item.variant}</div>
                            </td>
                            <td style="width: 25%;">
                                <div class="input-group input-group-sm">
                                    <button class="btn btn-xs btn-outline-secondary px-1 py-0" onclick="updateItemQtyInCart(${index}, -1)">-</button>
                                    <input type="text" class="form-control form-control-sm text-center p-0 shadow-none border-secondary" value="${item.qty}" readonly style="max-width:30px; font-size:0.75rem;" />
                                    <button class="btn btn-xs btn-outline-secondary px-1 py-0" onclick="updateItemQtyInCart(${index}, 1)">+</button>
                                </div>
                            </td>
                            <td class="text-end fw-medium text-dark" style="width: 20%;">${itemTotalPrice.toLocaleString('vi-VN')} đ</td>
                            <td class="text-center" style="width: 5%;">
                                <button class="btn btn-link text-danger p-0 border-0" onclick="deleteItemFromCart(${index})"><i class="bi bi-trash"></i></button>
                            </td>
                        </tr>`;
                });
            }

            $('#cartItemsBody').html(html);

            let finalPrice = totalCartPrice + totalVatPrice - activeTab.discountAmount;
            if(finalPrice < 0) finalPrice = 0;

            $('#lblTotalCartPrice').text(`${totalCartPrice.toLocaleString('vi-VN')} đ`);
            $('#lblTotalVatPrice').text(`${totalVatPrice.toLocaleString('vi-VN')} đ`);

            if(activeTab.discountAmount > 0) {
                $('#lblVoucherDiscount').text(`-${activeTab.discountAmount.toLocaleString('vi-VN')} đ`);
                $('#boxDiscount').removeClass('d-none');
            } else {
                $('#boxDiscount').addClass('d-none');
            }
            $('#lblFinalPrice').text(`${finalPrice.toLocaleString('vi-VN')} đ`);
            calculateRefundCash(finalPrice);
        }

        function updateItemQtyInCart(index, offset) {
            let activeTab = posTabs[activeTabIdx];
            let item = activeTab.items[index];
            let newQty = item.qty + offset;

            if(newQty <= 0) {
                deleteItemFromCart(index);
                return;
            }
            if(newQty > item.stock) {
                alert(`Không thể tăng số lượng mua vượt mức giới hạn tồn kho (${item.stock}).`);
                return;
            }
            item.qty = newQty;
            loadActiveTabToSidebarCart();
        }

        function deleteItemFromCart(index) {
            posTabs[activeTabIdx].items.splice(index, 1);
            renderTabsHeaders();
            loadActiveTabToSidebarCart();
        }

        function calculateRefundCash(finalPrice) {
            let cashGiven = parseFloat($('#numCustomerCash').val()) || 0;
            let finalAmt = finalPrice !== undefined ? finalPrice : (parseFloat($('#lblFinalPrice').text().replace(/\./g, '').replace(' đ', '')) || 0);

            if(cashGiven >= finalAmt && finalAmt > 0) {
                $('#lblRefundCash').text(`${(cashGiven - finalAmt).toLocaleString('vi-VN')} đ`);
            } else {
                $('#lblRefundCash').text('0 đ');
            }
        }

        // ==========================================
        // 3. TÌM KIẾM KHÁCH HÀNG VÀ THÊM NHANH AJAX
        // ==========================================
        $(document).ready(function() {
            initPOSSystemTabs();
            loadProductsFromWarehouse();

            setInterval(() => {
                let now = new Date();
                $('#lblLiveClock').text(now.toLocaleTimeString('vi-VN'));
            }, 1000);

            $('#txtProductSearch').on('input', function() {
                let val = $(this).val().trim();
                let foundProduct = localProductsCache.find(p => p.sku.toLowerCase() === val.toLowerCase());
                if(foundProduct) {
                    addProductToActiveCart(foundProduct.chiTietSanPhamID);
                    $(this).val('');
                }
            });

            $('#txtCustomerSearch').on('keyup', function() {
                let keyword = $(this).val().trim();
                if(keyword.length < 2) {
                    $('#customerSearchResults').addClass('d-none');
                    return;
                }

                $.ajax({
                    url: `/api/admin/pos/customers/search?keyword=${encodeURIComponent(keyword)}`,
                    type: 'GET',
                    success: function(res) {
                        if(res.length === 0) {
                            $('#customerSearchResults').addClass('d-none');
                            return;
                        }
                        let html = '';
                        res.forEach(c => {
                            html += `<button type="button" class="list-group-item list-group-item-action py-2 text-start small select-customer-row"
                                        data-id="${c.khachHangID}" data-name="${c.ten}" data-phone="${c.soDienThoai}">
                                        <i class="bi bi-telephone-outbound me-2"></i><strong>${c.ten}</strong> - ${c.soDienThoai}
                                     </button>`;
                        });
                        $('#customerSearchResults').html(html).removeClass('d-none');
                    }
                });
            });

            $(document).on('click', '.select-customer-row', function() {
                let tab = posTabs[activeTabIdx];
                tab.customerId = $(this).data('id');
                tab.customerName = $(this).data('name');
                tab.customerPhone = $(this).data('phone');

                $('#customerSearchResults').addClass('d-none');
                $('#txtCustomerSearch').val('');
                loadActiveTabToSidebarCart();
            });

            $('#btnRemoveSelectedCustomer').click(function() {
                let tab = posTabs[activeTabIdx];
                tab.customerId = 'KH000000';
                tab.customerName = 'Khách lẻ';
                tab.customerPhone = '0000000000';
                loadActiveTabToSidebarCart();
            });

            $('#btnSaveQuickCustomer').click(function() {
                let name = $('#txtNewCustomerName').val().trim();
                let phone = $('#txtNewCustomerPhone').val().trim();

                if(!name || !phone) { alert("Vui lòng điền đầy đủ Tên và SĐT khách hàng."); return; }

                $.ajax({
                    url: '/api/admin/pos/customers/quick-add',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify({ ten: name, soDienThoai: phone }),
                    success: function(res) {
                        alert(res.message);
                        let tab = posTabs[activeTabIdx];
                        tab.customerId = res.khachHangID;
                        tab.customerName = res.ten;
                        tab.customerPhone = res.soDienThoai;

                        $('#modalQuickAddCustomer').modal('hide');
                        $('#txtNewCustomerName,#txtNewCustomerPhone').val('');
                        loadActiveTabToSidebarCart();
                    },
                    error: function(err) { alert(err.responseJSON?.message || "Lỗi khi lưu khách hàng."); }
                });
            });

            $('input[name="paymentType"]').change(function() {
                if($(this).val() === "0") {
                    $('#cashCalculationBox').removeClass('d-none');
                } else {
                    $('#cashCalculationBox').addClass('d-none');
                }
            });

            $('#numCustomerCash').on('input', function() { calculateRefundCash(); });

                    // ==========================================
        // 4. XỬ LÝ GỬI ĐƠN LÊN BACKEND & GỌI LỆNH IN NHIỆT ẢO
        // ==========================================
        let currentFinalAmt = 0;
        let currentKieuPay = 0;

        $('#btnCompletePOSCheckout').click(function() {
            let activeTab = posTabs[activeTabIdx];
            if(activeTab.items.length === 0) { alert("Giỏ hàng đang trống, không thể thanh toán."); return; }

            currentFinalAmt = parseFloat($('#lblFinalPrice').text().replace(/\./g, '').replace(' đ', '')) || 0;
            currentKieuPay = parseInt($('input[name="paymentType"]:checked').val());

            if(currentKieuPay === 0) {
                // TRƯỜNG HỢP 1: TRẢ TIỀN MẶT -> Lưu DB & In hóa đơn luôn
                let cashGiven = parseFloat($('#numCustomerCash').val()) || 0;
                if(cashGiven < currentFinalAmt) { alert("Số tiền khách đưa chưa đủ để hoàn tất đơn hàng."); return; }
                processFinalCheckoutDB();
            }
            else if (currentKieuPay === 1) {
                // TRƯỜNG HỢP 2: CHUYỂN KHOẢN QR -> Gọi PayOS lấy link
                let btn = $(this);
                let originalText = btn.html();
                btn.prop('disabled', true).html('<i class="bi bi-hourglass-split"></i> Đang tạo mã QR...');

                $.ajax({
                    url: '/api/payment/create-payment',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify({ Amount: currentFinalAmt }), // Truyền số tiền thật
                    success: function(res) {
                        btn.prop('disabled', false).html(originalText);
                        if(res.success) {
                            // Đổ link PayOS vào Iframe và bật Pop-up lên
                            $('#iframePayOS').attr('src', res.checkoutUrl);
                            $('#modalQRCode').modal('show');
                        }
                    },
                    error: function(err) {
                        btn.prop('disabled', false).html(originalText);
                        alert("Lỗi khi tạo mã QR: " + (err.responseJSON?.message || ""));
                    }
                });
            }
        });

        // Khi thu ngân xác nhận tiền đã nổ Ting Ting -> Bấm nút trên Pop-up
        $('#btnConfirmQRPaid').click(function() {
            $('#modalQRCode').modal('hide');
            $('#iframePayOS').attr('src', ''); // Xóa dấu vết link cũ
            processFinalCheckoutDB(); // Lưu xuống DB và In hóa đơn
        });

        // HÀM XỬ LÝ LƯU DB & IN HÓA ĐƠN (Tách ra dùng chung)
        function processFinalCheckoutDB() {
            let activeTab = posTabs[activeTabIdx];
            let payloadItems = activeTab.items.map(item => {
                return { ChiTietSanPhamID: item.id, SoLuongMua: item.qty };
            });

            let checkoutPayload = {
                KhachHangID: activeTab.customerId,
                KhuyenMaiID: activeTab.voucherId || null,
                GhiChu: activeTab.note || "Bán trực tiếp tại quầy thu ngân",
                KieuThanhToan: currentKieuPay,
                MaThamChieu: currentKieuPay === 1 ? ("BANKPOS" + Date.now().toString().substring(7)) : "",
                Items: payloadItems
            };

            $.ajax({
                url: '/api/admin/pos/checkout',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(checkoutPayload),
                success: function(res) {
                    executeInvoicePrintJob(res.hoaDonId, res.thoiGian, activeTab);

                    // Dọn dẹp Tab sau khi thanh toán xong
                    if (posTabs.length > 1) {
                        posTabs.splice(activeTabIdx, 1);
                        if (activeTabIdx >= posTabs.length) { activeTabIdx = posTabs.length - 1; }
                    } else {
                        activeTab.items = [];
                        activeTab.customerId = 'KH000000';
                        activeTab.customerName = 'Khách lẻ';
                        activeTab.customerPhone = '0000000000';
                        activeTab.voucherId = '';
                        activeTab.voucherCode = '';
                        activeTab.discountAmount = 0;
                    }

                    $('#numCustomerCash').val('');
                    $('#txtVoucherCode').val('');
                    renderTabsHeaders();
                    loadActiveTabToSidebarCart();
                    loadProductsFromWarehouse();
                },
                error: function(err) { alert(err.responseJSON?.message || "Giao dịch thanh toán thất bại."); }
            });
        }

            function executeInvoicePrintJob(invoiceId, formattedTime, tabData) {
                let d = new Date(formattedTime);
                $('#printOrderTime').text(`Ngày: ${d.getDate()}/${d.getMonth()+1}/${d.getFullYear()} ${d.getHours()}:${d.getMinutes()}`);
                $('#printInvoiceId').text(`Mã HĐ: ${invoiceId}`);
                $('#printCustomer').text(tabData.customerId === 'KH000000' ? 'Khách lẻ' : `${tabData.customerName} - ${tabData.customerPhone}`);

                let htmlItems = '';
                let totalGoodsPrice = 0;
                let totalVatAmt = 0;

                tabData.items.forEach(item => {
                    let totalItem = item.price * item.qty;
                    totalGoodsPrice += totalItem;
                    totalVatAmt += (totalItem * item.vatRate / 100);
                    htmlItems += `
                        <tr>
                            <td>
                                <div><strong>${item.name}</strong></div>
                                <div style="font-size:9px; color:#555;">Phân loại: ${item.variant}</div>
                            </td>
                            <td style="text-align:center;">${item.qty}</td>
                            <td style="text-align:right;">${totalItem.toLocaleString('vi-VN')} đ</td>
                        </tr>`;
                });

                $('#printInvoiceItemsBody').html(htmlItems);
                $('#printTotalGoods').text(`${totalGoodsPrice.toLocaleString('vi-VN')} đ`);
                $('#printTotalVat').text(`${totalVatAmt.toLocaleString('vi-VN')} đ`);
                $('#printDiscount').text(`-${tabData.discountAmount.toLocaleString('vi-VN')} đ`);
                $('#printFinalAmount').text($('#lblFinalPrice').text());

                $('#invoice-print-template').removeClass('d-none');
                window.print();
                $('#invoice-print-template').addClass('d-none');
            }
        });
    </script>
</body>
</html>