@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Quản lý khuyến mãi & Voucher";
}

<div class="card p-4 bg-white">
    <div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-center gap-3 mb-4">
        <div>
            <h4 class="fw-bold text-dark mb-1">QUẢN LÝ KHUYẾN MÃI & VOUCHER</h4>
            <p class="text-muted small mb-0">Thiết lập chương trình giảm giá tự động hoặc tạo mã Voucher giới hạn cho ngày hội mua sắm.</p>
        </div>
        <button class="btn btn-dark btn-sm px-3 rounded-pill fw-medium" data-bs-toggle="modal" data-bs-target="#promoModal">
            <i class="bi bi-plus-circle me-1"></i> Tạo mã khuyến mãi
        </button>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th style="width: 50px;">STT</th>
                    <th>Mã ID</th>
                    <th>Tên Chương Trình</th>
                    <th>Mã Code (Voucher)</th>
                    <th>Hình Thức Giảm</th>
                    <th>Trị Giá</th>
                    <th>Thời Hạn Áp Dụng</th>
                    <th class="text-center">Đã Dùng / Tổng</th>
                    <th class="text-center">Trạng Thái</th>
                    <th class="text-center">Hành Động</th>
                </tr>
            </thead>
            <tbody id="promoTableBody">
            </tbody>
        </table>
        <div class="d-flex justify-content-between align-items-center mt-3">
            <div>
                <span class="small text-muted">
                    Hiển thị <span id="startRecord">0</span>-<span id="endRecord">0</span> trên tổng <span id="totalRecords">0</span>
                </span>
            </div>
            <nav>
                <ul class="pagination pagination-sm mb-0" id="pagination"></ul>
            </nav>
        </div>
    </div>
</div>

<div class="modal fade" id="promoModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title fw-bold text-dark">THIẾT LẬP CHƯƠNG TRÌNH KHUYẾN MÃI MỚI</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="createPromoForm">
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label small fw-bold">Tên chương trình khuyến mãi *</label>
                            <input type="text" class="form-control form-control-sm" id="formTen" required placeholder="Ví dụ: Giảm giá Giáng Sinh" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-bold">Mã Code nhập (Voucher)</label>
                            <input type="text" class="form-control form-control-sm" id="formMaCode" placeholder="Ví dụ: WINTER20 (Bỏ trống nếu tự động giảm)" />
                        </div>

                        <div class="col-md-4">
                            <label class="form-label small fw-bold">Hình thức giảm giá *</label>
                            <select class="form-select form-select-sm" id="formLoaiGiamGia">
                                <option value="1">Giảm theo phần trăm (%)</option>
                                <option value="0">Trừ thẳng tiền mặt (đ)</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small fw-bold">Mức giá trị giảm *</label>
                            <input type="number" class="form-control form-control-sm" id="formGiaTriGiam" required min="1" placeholder="Ví dụ: 20 hoặc 50000" />
                        </div>
                        <div class="col-md-4 div-percent-only">
                            <label class="form-label small fw-bold">
                                Mức giảm tối đa (Trần %)
                                <i class="bi bi-question-circle text-muted" data-bs-toggle="tooltip" data-bs-placement="top" title="Số tiền giảm tối đa khi áp dụng mã. Đặt 0 nếu không giới hạn."></i>
                            </label>
                            <input type="number" class="form-control form-control-sm" id="formGiamToiDa" value="0" min="0" placeholder="0 nếu không giới hạn" />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label small fw-bold">Phạm vi áp dụng ưu đãi *</label>
                            <select class="form-select form-select-sm" id="formPhamVi">
                                <option value="all">Toàn bộ cửa hàng (Toàn sàn)</option>
                                <option value="category">Áp dụng theo Danh mục sản phẩm</option>
                                <option value="product">Áp dụng cho Sản phẩm cụ thể</option>
                            </select>
                        </div>

                        <div class="col-md-6 d-none" id="divCategorySelect">
                            <label class="form-label small fw-bold">Chọn danh mục sản phẩm *</label>
                            <select class="form-select form-select-sm" id="formDanhMucId"></select>
                        </div>

                        <div class="col-12 d-none" id="divProductSelect">
                            <label class="form-label small fw-bold">Chọn các sản phẩm áp dụng * (Giữ Ctrl để chọn nhiều)</label>
                            <select class="form-select form-select-sm" id="formSanPhamIds" multiple style="height: 150px;"></select>
                            <small class="text-muted d-block mt-1">Mã giảm giá sẽ chỉ có hiệu lực với các sản phẩm được bôi xanh ở trên.</small>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label small fw-bold">Giá trị đơn hàng tối thiểu *</label>
                            <input type="number" class="form-control form-control-sm" id="formGiaTriToiThieuApDung" value="0" min="0" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-bold">Tổng số lượng mã phát hành *</label>
                            <input type="number" class="form-control form-control-sm" id="formSoLuongToiDa" value="100" min="1" required />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label small fw-bold">Ngày bắt đầu áp dụng *</label>
                            <input type="datetime-local" class="form-control form-control-sm" id="formNgayApDung" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-bold">Ngày kết thúc thời hạn *</label>
                            <input type="datetime-local" class="form-control form-control-sm" id="formNgayKetThuc" required />
                        </div>

                        <div class="col-12">
                            <label class="form-label small fw-bold">Mô tả ngắn</label>
                            <textarea class="form-control form-control-sm" id="formMoTa" rows="2" placeholder="Nội dung hiển thị cho khách hàng đọc..."></textarea>
                        </div>
                    </div>
                </div>
                <div class="modal-footer bg-light">
                    <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Hủy bỏ</button>
                    <button type="submit" class="btn btn-dark btn-sm px-4 fw-medium">Lưu và kích hoạt</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            $('#menu-promotions').addClass('active');

            const today = new Date().toISOString().slice(0, 16);
            $('#formNgayApDung').val(today);

            let currentPage = 1;
            const pageSize = 10;
            let allPromotions = [];

            loadPromotions();

            // NẠP TÀI NGUYÊN DANH MỤC & SẢN PHẨM
            $.get('/api/admin/promotions/resources')
                .done(function(res) {
                    let catHtml = '<option value="">-- Chọn danh mục sản phẩm --</option>';
                    if (res.categories && res.categories.length) {
                        res.categories.forEach(c => {
                            catHtml += `<option value="${c.danhMucID}">${c.ten}</option>`;
                        });
                    }
                    $('#formDanhMucId').html(catHtml);

                    let prodHtml = '';
                    if (res.products && res.products.length) {
                        res.products.forEach(p => {
                            prodHtml += `<option value="${p.sanPhamID}">[${p.sanPhamID}] - ${p.ten}</option>`;
                        });
                    }
                    $('#formSanPhamIds').html(prodHtml);
                })
                .fail(function(jqXHR) {
                    console.error("Lỗi tải tài nguyên khuyến mãi:", jqXHR.responseJSON?.message || "Không thể kết nối");
                    $('#formDanhMucId').html('<option value="">Lỗi tải danh mục</option>');
                    $('#formSanPhamIds').html('<option value="">Lỗi tải sản phẩm</option>');
                });

            // Ẩn/hiện ô "Mức giảm tối đa"
            $('#formLoaiGiamGia').change(function() {
                if ($(this).val() === '1') {
                    $('.div-percent-only').removeClass('d-none');
                } else {
                    $('.div-percent-only').addClass('d-none');
                    $('#formGiamToiDa').val('0');
                }
            }).trigger('change');

            // Điều khiển ẩn hiện các ô chọn dựa theo Phạm vi
            $('#formPhamVi').change(function() {
                const val = $(this).val();
                if (val === 'category') {
                    $('#divCategorySelect').removeClass('d-none');
                    $('#divProductSelect').addClass('d-none');
                } else if (val === 'product') {
                    $('#divProductSelect').removeClass('d-none');
                    $('#divCategorySelect').addClass('d-none');
                } else {
                    $('#divCategorySelect').addClass('d-none');
                    $('#divProductSelect').addClass('d-none');
                }
            });

            // 1. Hàm gọi API lấy danh sách khuyến mãi
            function loadPromotions() {
                $('#promoTableBody').html('<tr><td colspan="10" class="text-center py-4 text-muted"><div class="spinner-border spinner-border-sm me-2"></div>Đang tải danh sách ưu đãi...</td></tr>');
                $.get('/api/admin/promotions')
                    .done(function(data) {
                        allPromotions = data || [];
                        currentPage = 1;
                        renderPromotionsPage();
                    })
                    .fail(function(jqXHR, textStatus, errorThrown) {
                        console.error("Lỗi tải danh sách khuyến mãi:", textStatus, errorThrown);
                        $('#promoTableBody').html('<tr><td colspan="10" class="text-center text-danger py-4">Lỗi tải danh sách khuyến mãi. Vui lòng thử lại sau.</td></tr>');
                        $('#pagination').empty();
                        $('#startRecord').text('0');
                        $('#endRecord').text('0');
                        $('#totalRecords').text('0');
                    });
            }

            function renderPromotionsPage() {
                const start = (currentPage - 1) * pageSize;
                const end = Math.min(start + pageSize, allPromotions.length);
                const pageData = allPromotions.slice(start, end);

                let html = '';
                if (pageData.length === 0) {
                    html = '<tr><td colspan="10" class="text-center py-4 text-muted">Chưa có chương trình khuyến mãi nào được tạo.</td></tr>';
                } else {
                    pageData.forEach((promo, index) => {
                        const stt = start + index + 1;
                        // SỬA: Dùng trangThaiInt để xác định trạng thái (1 = HoatDong)
                        const isActived = promo.trangThaiInt === 1;
                        const valBadge = promo.loaiGiamGia.includes("%") ? `${promo.giaTriGiam}%` : `${promo.giaTriGiam.toLocaleString('vi-VN')}đ`;
                        html += `
                            <tr>
                                <td class="text-center small text-muted">${stt}</td>
                                <td class="text-secondary small font-monospace fw-bold">${promo.khuyenMaiId}</td>
                                <td class="fw-medium text-dark">${promo.ten}</td>
                                <td><span class="badge bg-light text-dark border font-monospace px-2 py-1">${promo.maCode}</span></td>
                                <td class="small">${promo.loaiGiamGia}</td>
                                <td class="fw-bold text-danger">${valBadge}</td>
                                <td class="small">${new Date(promo.ngayApDung).toLocaleDateString('vi-VN')} - ${new Date(promo.ngayKetThuc).toLocaleDateString('vi-VN')}</td>
                                <td class="text-center small fw-medium">${promo.soLuongDaDung} / ${promo.soLuongToiDa}</td>
                                <td class="text-center">
                                    <div class="form-check form-switch d-inline-block">
                                        <input class="form-check-input btn-toggle-promo" type="checkbox" data-id="${promo.khuyenMaiId}" ${isActived ? 'checked' : ''}>
                                        <label class="form-check-label small fw-bold ${isActived ? 'text-success' : 'text-danger'}">${promo.trangThai}</label>
                                    </div>
                                </td>
                                <td class="text-center">
                                    <button class="btn btn-sm btn-outline-dark btn-edit-promo me-1" data-id="${promo.khuyenMaiId}"><i class="bi bi-pencil-square"></i></button>
                                    <button class="btn btn-sm btn-outline-danger btn-delete-promo" data-id="${promo.khuyenMaiId}"><i class="bi bi-trash"></i></button>
                                </td>
                            </tr>`;
                    });
                }
                $('#promoTableBody').html(html);

                $('#startRecord').text(allPromotions.length > 0 ? start + 1 : 0);
                $('#endRecord').text(end);
                $('#totalRecords').text(allPromotions.length);

                const totalPages = Math.ceil(allPromotions.length / pageSize);
                let paginationHtml = '';
                if (totalPages > 1) {
                    paginationHtml += `<li class="page-item ${currentPage === 1 ? 'disabled' : ''}"><a class="page-link" href="#" data-page="${currentPage - 1}">«</a></li>`;
                    for (let i = 1; i <= totalPages; i++) {
                        paginationHtml += `<li class="page-item ${i === currentPage ? 'active' : ''}"><a class="page-link" href="#" data-page="${i}">${i}</a></li>`;
                    }
                    paginationHtml += `<li class="page-item ${currentPage === totalPages ? 'disabled' : ''}"><a class="page-link" href="#" data-page="${currentPage + 1}">»</a></li>`;
                }
                $('#pagination').html(paginationHtml);
            }

            // 2. Xử lý Bật/Tắt trạng thái hoạt động (ĐÃ SỬA)
            $(document).on('change', '.btn-toggle-promo', function() {
                const checkbox = $(this);
                const promoId = checkbox.data('id');
                // Lưu trạng thái hiện tại trước khi gửi để khôi phục nếu lỗi
                const previousChecked = checkbox.is(':checked');

                $.ajax({
                    url: `/api/admin/promotions/${promoId}/toggle-status`,
                    type: 'PUT',
                    success: function(res) {
                        const label = checkbox.closest('.form-check').find('.form-check-label');
                        label.text(res.currentStatus);
                        const isActive = res.currentStatusInt === 1; // 1 = HoatDong
                        if (isActive) {
                            label.removeClass('text-danger').addClass('text-success');
                            checkbox.prop('checked', true);
                        } else {
                            label.removeClass('text-success').addClass('text-danger');
                            checkbox.prop('checked', false);
                        }
                    },
                    error: function(jqXHR) {
                        alert(jqXHR.responseJSON?.message || "Không thể chuyển đổi trạng thái khuyến mãi.");
                        // Khôi phục trạng thái checkbox ban đầu
                        checkbox.prop('checked', previousChecked);
                    }
                });
            });

            // 3. Xử lý Form Thêm mới / Sửa
            $('#createPromoForm').submit(function(e) {
                e.preventDefault();
                const editId = $('#promoModal').attr('data-edit-id');
                const isEdit = !!editId;

                let selectedProductIds = [];
                if ($('#formPhamVi').val() === 'product') {
                    selectedProductIds = $('#formSanPhamIds').val() || [];
                    if (selectedProductIds.length === 0) {
                        alert("Vui lòng chọn ít nhất một sản phẩm!");
                        return;
                    }
                }

                if ($('#formPhamVi').val() === 'category' && !$('#formDanhMucId').val()) {
                    alert("Vui lòng chọn danh mục sản phẩm áp dụng!");
                    return;
                }

                const payload = {
                    ten: $('#formTen').val(),
                    maCode: $('#formMaCode').val(),
                    moTa: $('#formMoTa').val(),
                    loaiGiamGia: parseInt($('#formLoaiGiamGia').val()),
                    giaTriGiam: parseFloat($('#formGiaTriGiam').val()),
                    giamToiDa: parseFloat($('#formGiamToiDa').val()),
                    giaTriToiThieuApDung: parseFloat($('#formGiaTriToiThieuApDung').val()),
                    soLuongToiDa: parseInt($('#formSoLuongToiDa').val()),
                    ngayApDung: new Date($('#formNgayApDung').val()).toISOString(),
                    ngayKetThuc: new Date($('#formNgayKetThuc').val()).toISOString(),
                    phamVi: $('#formPhamVi').val(),
                    danhMucId: $('#formDanhMucId').val() || null,
                    sanPhamIds: selectedProductIds
                };

                const url = isEdit ? `/api/admin/promotions/${editId}` : '/api/admin/promotions';
                const method = isEdit ? 'PUT' : 'POST';

                $.ajax({
                    url: url,
                    type: method,
                    contentType: 'application/json',
                    data: JSON.stringify(payload),
                    success: function() {
                        $('#promoModal').modal('hide');
                        $('#promoModal').removeAttr('data-edit-id');
                        $('#promoModal .modal-title').text('THIẾT LẬP CHƯƠNG TRÌNH KHUYẾN MÃI MỚI');
                        $('#createPromoForm')[0].reset();
                        $('#formPhamVi').val('all').trigger('change');
                        loadPromotions();
                    },
                    error: function(jqXHR) {
                        alert(jqXHR.responseJSON?.message || "Lỗi xử lý chương trình ưu đãi.");
                    }
                });
            });

            // 4. Xử lý xóa mã giảm giá
            $(document).on('click', '.btn-delete-promo', function() {
                const promoId = $(this).data('id');
                if (!confirm("Bạn có chắc chắn muốn xóa vĩnh viễn mã giảm giá này không?")) return;

                $.ajax({
                    url: `/api/admin/promotions/${promoId}`,
                    type: 'DELETE',
                    success: function(res) {
                        alert(res.message);  // Thông báo thành công
                        loadPromotions();
                    },
                    error: function(jqXHR) {
                        alert(jqXHR.responseJSON?.message || "Lỗi không thể xóa chương trình.");
                    }
                });
            });

                    // 5. Xử lý nút Sửa
        $(document).on('click', '.btn-edit-promo', function() {
            const promoId = $(this).data('id');
            $.get(`/api/admin/promotions/${promoId}`)
                .done(function(promo) {
                    $('#promoModal').attr('data-edit-id', promoId);
                    $('#promoModal .modal-title').text('CHỈNH SỬA CHƯƠNG TRÌNH KHUYẾN MÃI');
                    $('#formTen').val(promo.ten);
                    $('#formMaCode').val(promo.maCode);
                    $('#formMoTa').val(promo.moTa);
                    $('#formLoaiGiamGia').val(promo.loaiGiamGia).trigger('change');
                    $('#formGiaTriGiam').val(promo.giaTriGiam);
                    $('#formGiamToiDa').val(promo.giamToiDa);
                    $('#formGiaTriToiThieuApDung').val(promo.giaTriToiThieuApDung);
                    $('#formSoLuongToiDa').val(promo.soLuongToiDa);
                    $('#formNgayApDung').val(new Date(promo.ngayApDung).toISOString().slice(0, 16));
                    $('#formNgayKetThuc').val(new Date(promo.ngayKetThuc).toISOString().slice(0, 16));

                    // Xác định phạm vi và điền dữ liệu
                    if (promo.danhMucId) {
                        // Phạm vi danh mục
                        $('#formPhamVi').val('category').trigger('change');
                        $('#formDanhMucId').val(promo.danhMucId);
                    } else if (promo.danhSachSanPhamApDung && promo.danhSachSanPhamApDung.length > 0) {
                        // Phạm vi sản phẩm
                        $('#formPhamVi').val('product').trigger('change');
                        const productIds = promo.danhSachSanPhamApDung.map(p => p.sanPhamId);
                        $('#formSanPhamIds').val(productIds);
                    } else {
                        // Toàn sàn hoặc không xác định
                        $('#formPhamVi').val('all').trigger('change');
                    }

                    $('#promoModal').modal('show');
                })
                .fail(function(jqXHR) {
                    alert(jqXHR.responseJSON?.message || "Lỗi tải thông tin khuyến mãi.");
                });
        });

            // 6. Xử lý phân trang (giữ nguyên)
            $(document).on('click', '#pagination .page-link', function(e) {
                e.preventDefault();
                const page = parseInt($(this).data('page'));
                if (page && page !== currentPage && page >= 1 && page <= Math.ceil(allPromotions.length / pageSize)) {
                    currentPage = page;
                    renderPromotionsPage();
                    $('html, body').animate({ scrollTop: $('#promoTableBody').offset().top - 100 }, 200);
                }
            });
        });
    </script>
    <style>
        .form-check-label {
            white-space: nowrap;
            min-width: 100px; /* <-- THÊM DÒNG NÀY để tránh cột bị nở */
            display: inline-block;
        }
    </style>
}