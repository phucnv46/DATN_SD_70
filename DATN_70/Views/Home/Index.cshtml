@model DATN_70.Models.ViewModels.HomeIndexViewModel
@{
    ViewData["Title"] = "Trang chủ";
    var banners = Model?.Banners ?? new List<DATN_70.Models.ViewModels.HomeBannerViewModel>();
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<section id="homePage" class="page-section home-page" data-banner-count="@banners.Count">
    <div class="container">

        <section class="hero-banner @(banners.Count > 1 ? "is-slideshow" : "is-static")" data-interval="7000">
            @if (banners.Count == 0)
            {
                <div class="empty-state">Chưa có banner nào được kích hoạt.</div>
            }
            else
            {
                <div class="hero-banner-track">
                    @for (var i = 0; i < banners.Count; i++)
                    {
                        var banner = banners[i];
                        <article class="hero-slide @(i == 0 ? "active" : string.Empty)" data-slide-index="@i">
                            <a class="hero-slide-link" href="@banner.LinkUrl">
                                <img src="@banner.ImageUrl" alt="@banner.Title" class="hero-slide-image" />
                                <div class="hero-slide-overlay">
                                    <div class="hero-slide-topline">
                                        <span class="eyebrow-text">Winter Shop</span>
                                        <span class="hero-slide-index">@(i + 1).0@(banners.Count)</span>
                                    </div>
                                    <div class="hero-slide-copy">
                                        <h1>@banner.Title</h1>
                                        @if (!string.IsNullOrWhiteSpace(banner.Description))
                                        {
                                            <p>@banner.Description</p>
                                        }
                                    </div>
                                    <div class="hero-slide-actions">
                                        <span class="btn btn-brand">Khám phá ngay</span>
                                        <span class="hero-slide-meta">Lookbook mùa lạnh được quản lý trực tiếp từ dashboard</span>
                                    </div>
                                </div>
                            </a>
                        </article>
                    }
                </div>
                @if (banners.Count > 1)
                {
                    <div class="hero-banner-nav" aria-label="Banner controls">
                        <button type="button" class="hero-nav-button" data-slide-direction="prev" aria-label="Banner trước">
                            <span>&larr;</span>
                        </button>
                        <button type="button" class="hero-nav-button" data-slide-direction="next" aria-label="Banner tiếp theo">
                            <span>&rarr;</span>
                        </button>
                    </div>
                    <div class="hero-dots" aria-label="Banner dots">
                        @for (var i = 0; i < banners.Count; i++)
                        {
                            <button type="button" class="hero-dot @(i == 0 ? "active" : string.Empty)" data-slide-to="@i" aria-label="Banner @(i + 1)"></button>
                        }
                    </div>
                }
            }
        </section>

        <section class="home-feature-grid my-4">
            <article class="home-feature-card p-4 d-flex align-items-start gap-3">
                <div class="fs-2 text-dark"><i class="bi bi-lightning-charge-fill"></i></div>
                <div>
                    <strong class="fs-5 d-block mb-1">Giao diện mua nhanh</strong>
                    <p class="text-muted m-0">Chọn màu, size và thêm giỏ hàng nhanh chóng ngay trên trang chủ, không cần chuyển hướng nhiều lần.</p>
                </div>
            </article>
            <article class="home-feature-card p-4 d-flex align-items-start gap-3">
                <div class="fs-2 text-dark"><i class="bi bi-shield-check"></i></div>
                <div>
                    <strong class="fs-5 d-block mb-1">Thủ tục thanh toán gọn nhẹ</strong>
                    <p class="text-muted m-0">Khách hàng đã đăng nhập có thể tự động lấy thông tin hồ sơ và địa chỉ mặc định khi tiến hành thanh toán.</p>
                </div>
            </article>
            <article class="home-feature-card p-4 d-flex align-items-start gap-3">
                <div class="fs-2 text-dark"><i class="bi bi-truck"></i></div>
                <div>
                    <strong class="fs-5 d-block mb-1">Theo dõi đơn rõ ràng</strong>
                    <p class="text-muted m-0">Trạng thái đơn hàng được bóc tách theo từng mốc thời gian giúp người mua dễ dàng theo dõi hành trình đơn.</p>
                </div>
            </article>
        </section>

        <section class="home-block my-5">
            <div class="d-flex justify-content-between align-items-end mb-4">
                <div>
                    <h2 class="fw-bold fs-3 m-0">Bộ sưu tập nổi bật</h2>
                    <p class="text-muted m-0">Đi thẳng vào nhóm sản phẩm bán tốt và thịnh hành nhất trong mùa lạnh năm nay.</p>
                </div>
                <a class="btn btn-outline-dark border-2 fw-bold" asp-controller="Home" asp-action="Products">Xem tất cả</a>
            </div>

            <div class="row row-cols-1 row-cols-sm-2 row-cols-md-4 g-4">
                @if (Model?.FeaturedProducts == null || !Model.FeaturedProducts.Any())
                {
                    <div class="col-12 w-100">
                        <div class="empty-state text-center py-5">Hiện chưa có sản phẩm nào hiển thị.</div>
                    </div>
                }
                else
                {
                    @foreach (var product in Model.FeaturedProducts)
                    {
                        <div class="col">
                            <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden position-relative product-card-hover">
                                <span class="position-absolute top-0 start-0 badge bg-dark m-3 rounded-pill px-3 py-2 fw-bold text-uppercase" style="z-index: 2; font-size: 0.7rem;">@product.DanhMuc</span>

                                @if (product.GiaThapNhat < product.GiaGoc)
                                {
                                    <span class="position-absolute top-0 end-0 badge bg-danger m-3 rounded-pill px-3 py-2 fw-bold" style="z-index: 2; font-size: 0.7rem;">
                                        -@product.PhanTramGiam.ToString("N0")%
                                    </span>
                                }

                                <a asp-controller="Home" asp-action="Details" asp-route-id="@product.SanPhamID" class="text-decoration-none text-dark d-block">
                                    <div class="ratio ratio-1x1 bg-light">
                                        <img src="@product.HinhAnhUrl" alt="@product.TenSanPham" class="img-fluid object-fit-cover w-100 h-100" loading="lazy" onerror="this.onerror=null; this.src='/images/default-product.png'" />
                                    </div>
                                    <div class="card-body p-3 d-flex flex-column justify-content-between" style="min-height: 120px;">
                                        <div>
                                            <h5 class="card-title fw-bold fs-6 text-truncate mb-1" title="@product.TenSanPham">@product.TenSanPham</h5>
                                            <p class="card-text text-muted small text-truncate mb-2">@product.MoTaNgan</p>
                                        </div>
                                        <div class="d-flex align-items-center gap-2">
                                            @if (product.GiaThapNhat < product.GiaGoc)
                                            {
                                                <span class="text-muted text-decoration-line-through small">@product.GiaGoc.ToString("N0") đ</span>
                                                <span class="text-danger fw-extrabold fs-5">@product.GiaThapNhat.ToString("N0") đ</span>
                                            }
                                            else
                                            {
                                                <span class="text-danger fw-extrabold fs-5">@product.GiaGoc.ToString("N0") đ</span>
                                            }
                                        </div>
                                    </div>
                                </a>
                            </div>
                        </div>
                    }
                }
            </div>
        </section>

        <section class="home-block promo-shelf p-4 rounded-5 my-5" style="background: linear-gradient(180deg, #fbf7f0 0%, #ffffff 100%);">
            <div class="d-flex justify-content-between align-items-end mb-4">
                <div>
                    <h2 class="fw-bold fs-3 text-dark m-0"><i class="bi bi-fire text-danger me-2"></i>Sản phẩm ưu đãi sâu</h2>
                    <p class="text-muted m-0">Các mẫu áo khoác thời thượng sở hữu mức giá tốt nhất thời điểm hiện tại.</p>
                </div>
            </div>

            <div class="row row-cols-1 row-cols-sm-2 row-cols-md-4 g-4">
                @if (Model?.SaleProducts == null || !Model.SaleProducts.Any())
                {
                    <div class="col-12 w-100">
                        <div class="empty-state text-center py-5">Không có sản phẩm ưu đãi nào khả dụng.</div>
                    </div>
                }
                else
                {
                    @foreach (var product in Model.SaleProducts)
                    {
                        <div class="col">
                            <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden position-relative">
                                @if (product.GiaThapNhat < product.GiaGoc)
                                {
                                    <span class="position-absolute top-0 end-0 badge bg-danger m-3 rounded-pill px-3 py-2 fw-bold" style="z-index: 2; font-size: 0.7rem;">
                                        -@product.PhanTramGiam.ToString("N0")%
                                    </span>
                                }
                                <a asp-controller="Home" asp-action="Details" asp-route-id="@product.SanPhamID" class="text-decoration-none text-dark d-block">
                                    <div class="ratio ratio-1x1 bg-light">
                                        <img src="@product.HinhAnhUrl" alt="@product.TenSanPham" class="img-fluid object-fit-cover w-100 h-100" loading="lazy" onerror="this.onerror=null; this.src='/images/default-product.png'" />
                                    </div>
                                    <div class="card-body p-3">
                                        <h5 class="card-title fw-bold fs-6 text-truncate mb-1">@product.TenSanPham</h5>
                                        <div class="d-flex align-items-center gap-2 mt-2">
                                            @if (product.GiaThapNhat < product.GiaGoc)
                                            {
                                                <span class="text-muted text-decoration-line-through small">@product.GiaGoc.ToString("N0") đ</span>
                                                <span class="text-danger fw-bold">@product.GiaThapNhat.ToString("N0") đ</span>
                                            }
                                            else
                                            {
                                                <span class="text-danger fw-bold">@product.GiaGoc.ToString("N0") đ</span>
                                            }
                                        </div>
                                    </div>
                                </a>
                            </div>
                        </div>
                    }
                }
            </div>
        </section>

    </div>
</section>

<style>
    .product-card-hover {
        transition: transform 0.25s ease, box-shadow 0.25s ease;
    }

        .product-card-hover:hover {
            transform: translateY(-6px);
            box-shadow: 0 15px 30px rgba(0,0,0,0.1) !important;
        }

    .fw-extrabold {
        font-weight: 800;
    }
</style>