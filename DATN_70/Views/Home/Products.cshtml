@model List<DATN_70.Models.ViewModels.HomeProductViewModel>
@{
    ViewData["Title"] = "Tất cả sản phẩm";
}

<section class="py-5 bg-light min-vh-100">
    <div class="container">

        <div class="row align-items-end mb-4">
            <div class="col-12">
                <h1 class="fw-bold mb-1">Cửa hàng thời trang</h1>
                <p class="text-muted mb-0">Tìm thấy @Model.Count sản phẩm phù hợp.</p>
            </div>
        </div>

        <div class="row">
            <div class="col-lg-3 mb-4">
                <div class="card border-0 shadow-sm rounded-4 sticky-top" style="top: 100px; z-index: 1;">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <h5 class="fw-bold m-0"><i class="bi bi-funnel me-2"></i>Bộ lọc</h5>
                            <a asp-controller="Home" asp-action="Products" class="text-danger small text-decoration-none fw-bold">Xóa lọc</a>
                        </div>

                        <form method="get" asp-controller="Home" asp-action="Products">

                            <div class="mb-3">
                                <label class="form-label fw-bold small text-muted text-uppercase">Danh mục</label>
                                <select name="category" class="form-select rounded-3">
                                    <option value="all" selected="@(ViewBag.CurrentCategory == "all")">Tất cả danh mục</option>
                                    @if (ViewBag.Categories != null)
                                    {
                                        foreach (var cat in ViewBag.Categories)
                                        {
                                            <option value="@cat.DanhMucID" selected="@(ViewBag.CurrentCategory == cat.DanhMucID)">@cat.Ten</option>
                                        }
                                    }
                                </select>
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-bold small text-muted text-uppercase">Kích cỡ (Size)</label>
                                <select name="size" class="form-select rounded-3">
                                    <option value="all" selected="@(ViewBag.CurrentSize == "all")">Tất cả các size</option>
                                    @if (ViewBag.Sizes != null)
                                    {
                                        foreach (var size in ViewBag.Sizes)
                                        {
                                            <option value="@size.KichCoID" selected="@(ViewBag.CurrentSize == size.KichCoID)">@size.Ten</option>
                                        }
                                    }
                                </select>
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-bold small text-muted text-uppercase">Tên sản phẩm</label>
                                <input type="text" name="search" class="form-control rounded-3" placeholder="Nhập từ khóa tìm..." value="@ViewBag.CurrentSearch">
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-bold small text-muted text-uppercase">Khoảng giá (VNĐ)</label>
                                <div class="d-flex align-items-center gap-2">
                                    <input type="number" name="minPrice" class="form-control rounded-3 form-control-sm" placeholder="Từ" value="@ViewBag.CurrentMinPrice">
                                    <span class="text-muted">-</span>
                                    <input type="number" name="maxPrice" class="form-control rounded-3 form-control-sm" placeholder="Đến" value="@ViewBag.CurrentMaxPrice">
                                </div>
                            </div>

                            <div class="mb-4">
                                <label class="form-label fw-bold small text-muted text-uppercase">Sắp xếp theo</label>
                                <select name="sort" class="form-select rounded-3">
                                    <option value="default" selected="@(ViewBag.CurrentSort == "default")">Mới nhất</option>
                                    <option value="price-asc" selected="@(ViewBag.CurrentSort == "price-asc")">Giá: Thấp - Cao</option>
                                    <option value="price-desc" selected="@(ViewBag.CurrentSort == "price-desc")">Giá: Cao - Thấp</option>
                                    <option value="name-asc" selected="@(ViewBag.CurrentSort == "name-asc")">Tên: A - Z</option>
                                </select>
                            </div>

                            <button type="submit" class="btn btn-dark w-100 rounded-3 py-2 fw-bold">Áp dụng bộ lọc</button>
                        </form>
                    </div>
                </div>
            </div>

            <div class="col-lg-9">
                <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 g-4">
                    @if (!Model.Any())
                    {
                        <div class="col-12 w-100 text-center py-5 bg-white rounded-4 shadow-sm">
                            <div class="fs-1 text-muted mb-3"><i class="bi bi-box-seam"></i></div>
                            <h5 class="fw-bold">Không có mặt hàng nào phù hợp!</h5>
                            <p class="text-muted">Ngọc hãy thử đổi một danh mục hoặc khoảng giá khác nhé.</p>
                        </div>
                    }
                    else
                    {
                        @foreach (var product in Model)
                        {
                            <div class="col">
                                <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden position-relative product-card-hover">
                                    <span class="position-absolute top-0 start-0 badge bg-dark m-3 rounded-pill px-3 py-2 fw-bold text-uppercase" style="z-index: 2; font-size: 0.7rem;">@product.DanhMuc</span>

                                    <a asp-controller="Home" asp-action="Details" asp-route-id="@product.SanPhamID" class="text-decoration-none text-dark d-block">
                                        <div class="ratio ratio-1x1 bg-light">
                                            <img src="@product.HinhAnhUrl" alt="@product.TenSanPham" class="img-fluid object-fit-cover w-100 h-100" loading="lazy" />
                                        </div>
                                        <div class="card-body p-3 d-flex flex-column justify-content-between" style="min-height: 120px;">
                                            <div>
                                                <h5 class="card-title fw-bold fs-6 text-truncate mb-1" title="@product.TenSanPham">@product.TenSanPham</h5>
                                            </div>
                                            <div class="d-flex align-items-center gap-2 mt-2">
                                                <span class="text-danger fw-extrabold fs-5">@product.GiaThapNhat.ToString("N0") đ</span>
                                            </div>
                                        </div>
                                    </a>
                                </div>
                            </div>
                        }
                    }
                </div>
